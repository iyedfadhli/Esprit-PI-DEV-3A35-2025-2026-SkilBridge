{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Révision Candidature - Skill Bridge{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/frontoffice/cv/cv.css') }}">
    <style>
        .review-panel {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 5px solid #007bff;
        }
        .review-actions {
            display: flex;
            gap: 15px;
        }
        .btn-accept { background: #28a745; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; }
        .btn-reject { background: #dc3545; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; }
        .btn-accept:hover { background: #218838; }
        .btn-reject:hover { background: #c82333; }
        .status-badge {
            padding: 8px 15px;
            border-radius: 20px;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 12px;
        }
    </style>
{% endblock %}

{% block body %}
<section class="cv-section">

    <div class="section-header">
        <div>
            <h1>Révision de la candidature</h1>
            <p class="section-subtitle">Offre : {{ offer.title }} | Candidat : {{ cv.user.nom }} {{ cv.user.prenom }}</p>
        </div>
        <a href="{{ path('entreprise_offer_applications', {id: offer.id}) }}" class="btn-secondary">
            <i class="fa fa-arrow-left"></i> Retour aux candidatures
        </a>
    </div>

    <!-- Panel de décision -->
    <div class="review-panel">
        <div>
            <span class="status-badge status-{{ application.status }}">Statut actuel : {{ application.status }}</span>
        </div>
        <div class="review-actions">
            <form action="{{ path('entreprise_application_update_status', {id: application.id}) }}" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="accepted">
                <button type="submit" class="btn-accept"><i class="fa fa-check"></i> Accepter</button>
            </form>
            <form action="{{ path('entreprise_application_update_status', {id: application.id}) }}" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="rejected">
                <button type="submit" class="btn-reject"><i class="fa fa-times"></i> Refuser</button>
            </form>
        </div>
    </div>

    <div class="cv-display">
        {# -- Header -- #}
        <div class="cv-display-header">
            <p class="cv-name-label">Profil Candidat</p>
            <h1>{{ cv.user.prenom }} {{ cv.user.nom }}</h1>
            <div class="cv-display-meta">
                <span><i class="fa fa-envelope"></i> {{ cv.user.email }}</span>
                {% if cv.linkedinUrl %}
                    <span><i class="fa fa-linkedin"></i> <a href="{{ cv.linkedinUrl }}" target="_blank">LinkedIn</a></span>
                {% endif %}
            </div>
        </div>

        <div class="cv-display-body">
            {# -- Summary -- #}
            {% if cv.summary %}
                <div class="cv-display-section">
                    <h2><i class="fa fa-user"></i> Résumé professionnel</h2>
                    <p class="cv-summary-text">{{ cv.summary|nl2br }}</p>
                </div>
            {% endif %}

            {# -- Experiences -- #}
            {% if experiences|length > 0 %}
                <div class="cv-display-section">
                    <h2><i class="fa fa-briefcase"></i> Expériences</h2>
                    {% for exp in experiences %}
                        <div class="cv-entry">
                            <div class="cv-entry-title">{{ exp.jobTitle }}</div>
                            <div class="cv-entry-sub">{{ exp.company }} | {{ exp.location }}</div>
                            <div class="cv-entry-date">
                                {{ exp.startDate|date('m/Y') }} - {% if exp.currentlyWorking %}Présent{% else %}{{ exp.endDate|date('m/Y') }}{% endif %}
                            </div>
                            <div class="cv-entry-desc">{{ exp.description|nl2br }}</div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# -- Education -- #}
            {% if educations|length > 0 %}
                <div class="cv-display-section">
                    <h2><i class="fa fa-graduation-cap"></i> Formation</h2>
                    {% for edu in educations %}
                        <div class="cv-entry">
                            <div class="cv-entry-title">{{ edu.degree }}</div>
                            <div class="cv-entry-sub">{{ edu.school }}</div>
                            <div class="cv-entry-date">{{ edu.startDate|date('Y') }} - {{ edu.endDate|date('Y') }}</div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# -- Skills -- #}
            {% if skills|length > 0 %}
                <div class="cv-display-section">
                    <h2><i class="fa fa-cogs"></i> Compétences</h2>
                    <div class="cv-skills-list">
                        {% for skill in skills %}
                            <span class="cv-skill-tag {{ skill.type }}">{{ skill.nom }} ({{ skill.level }})</span>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

</section>
{% endblock %}
