{% block javascripts %}
{{ parent() }}
<script>
    function addCollectionItem(collectionId) {
        const container = document.getElementById(collectionId + '-container');
        const prototype = container.dataset.prototype;
        const index = parseInt(container.dataset.index);

        let newForm = prototype.replace(/__name__/g, index);
        container.dataset.index = index + 1;

        const div = document.createElement('div');
        div.classList.add('entry-block');
        div.innerHTML = `
                <button type="button" class="btn-remove-entry" onclick="this.parentElement.remove()">
                    <i class="fa fa-times"></i>
                </button>
                <span class="entry-number">${collectionId.charAt(0).toUpperCase() + collectionId.slice(1, -1)} ${index + 1}</span>
                <div class="form-content-wrapper">
                    ${newForm}
                </div>
            `;

        container.appendChild(div);
    }
</script>
{% endblock %}