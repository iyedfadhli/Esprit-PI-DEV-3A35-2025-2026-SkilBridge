{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Créer un CV - Skill Bridge{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/cv/cv.css') }}">
{% endblock %}

{% block body %}
<section class="cv-section">

    <div class="section-header">
        <div>
            <h1>Créer un nouveau CV</h1>
            <p class="section-subtitle">Remplissez les informations de votre CV</p>
        </div>

        <a href="{{ path('preview_front_cv_index') }}" class="btn-secondary">
            <i class="fa fa-arrow-left"></i> Retour
        </a>
    </div>

    {# Désactivation de HTML5 et ajout de l'id pour JS #}
    {{ form_start(form, {'attr': {'class': 'cv-form-wrapper', 'id': 'cvForm', 'novalidate': 'novalidate'}}) }}
    <div class="global-errors">
        {{ form_errors(form) }}
    </div>

    {# --- Section 1: Informations générales --- #}
    <div class="cv-form-section">
        <h2><i class="fa fa-info-circle"></i> Informations générales</h2>
        <p class="section-desc">Donnez un nom à votre CV et choisissez la langue</p>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.nomCv) }}
                {{ form_widget(form.nomCv, {'attr': {'class': 'form-control' ~ (not form.nomCv.vars.valid ? '
                is-invalid' : '')}}) }}
                {{ form_errors(form.nomCv) }}
            </div>
            <div class="form-group">
                {{ form_label(form.langue) }}
                {{ form_widget(form.langue, {'attr': {'class': 'form-control' ~ (not form.langue.vars.valid ? '
                is-invalid' : '')}}) }}
                {{ form_errors(form.langue) }}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.linkedinUrl) }}
                {{ form_widget(form.linkedinUrl, {'attr': {'class': 'form-control' ~ (not form.linkedinUrl.vars.valid ?
                ' is-invalid' : '')}}) }}
                {{ form_errors(form.linkedinUrl) }}
            </div>
            <div class="form-group">
                {{ form_label(form.idTemplate) }}
                {{ form_widget(form.idTemplate, {'attr': {'class': 'form-control' ~ (not form.idTemplate.vars.valid ? '
                is-invalid' : '')}}) }}
                {{ form_errors(form.idTemplate) }}
            </div>
        </div>

        <div class="form-row single">
            <div class="form-group">
                {{ form_label(form.summary) }}
                {{ form_widget(form.summary, {'attr': {'class': 'form-control' ~ (not form.summary.vars.valid ? '
                is-invalid' : ''), 'rows': 4}}) }}
                {{ form_errors(form.summary) }}
            </div>
        </div>
    </div>

