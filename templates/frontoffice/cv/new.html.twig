            <div class="entry-block">
                <button type="button" class="btn-remove-entry" onclick="this.parentElement.remove()">
                    <i class="fa fa-times"></i>
                </button>
                <span class="entry-number">Expérience {{ loop.index }}</span>
                <div class="form-content-wrapper">
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(experienceField.jobTitle) }}
                            {{ form_widget(experienceField.jobTitle, {'attr': {'class': 'form-control' ~ (not
                            experienceField.jobTitle.vars.valid ? ' is-invalid' : '')}}) }}
                            {{ form_errors(experienceField.jobTitle) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(experienceField.company) }}
                            {{ form_widget(experienceField.company, {'attr': {'class': 'form-control' ~ (not
                            experienceField.company.vars.valid ? ' is-invalid' : '')}}) }}
                            {{ form_errors(experienceField.company) }}
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(experienceField.location) }}
                            {{ form_widget(experienceField.location, {'attr': {'class': 'form-control' ~ (not
