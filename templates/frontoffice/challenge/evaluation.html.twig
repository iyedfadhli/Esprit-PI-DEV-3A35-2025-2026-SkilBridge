{% extends 'frontoffice/base_front.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/challenge/evaluation_challenge.css') }}">
{% endblock %}

{% block body %}
	<section class="about-section">
		<div class="section-header">
			<p class="section-subtitle">Supervisor Area</p>
			<h2 class="section-title">My Challenges with Submitted Activities</h2>
		</div>

		<div class="modules">
			{% for challenge in challenges %}
<div class="challenge-wrapper">
    <div class="module-card">
        <div class="module-icon">📘</div>
        <h3>{{ challenge.title }}</h3>
        <p class="challenge-meta">Activities Submitted</p>
        <button class="signin-btn toggle-groups">See Groups</button>
    </div>

    <div class="groups-container">
        {% for group in groups[challenge.id] %}
        <div class="group-card">
            <h4>{{ group.name }}</h4>
            <a class="signin-btn" href="{{ path('evaluation_group_activities', {'challengeId': challenge.id, 'groupId': group.id}) }}">See Activity</a>
        </div>
        {% endfor %}
    </div>
</div>
{% else %}
<p>No challenges found for this user.</p>
{% endfor %}

<!-- Modal removed -->

	</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.toggle-groups').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const container = btn.parentElement.nextElementSibling;
      if (!container) return;
      if (container.style.maxHeight && container.style.maxHeight !== '0px') {
        container.style.maxHeight = '0';
        container.style.opacity = 0;
      } else {
        container.style.maxHeight = container.scrollHeight + 'px';
        container.style.opacity = 1;
      }
    });
  });
});
</script>
{% endblock %}
