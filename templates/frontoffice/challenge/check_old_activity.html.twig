{% extends 'frontoffice/base_front.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/challenge/activity_challenge.css') }}">
	<style>
		/* Table Styling */
		.activity-table {
			width: 100%;
			border-collapse: collapse;
			margin-top: 20px;
			font-family: Arial, sans-serif;
		}

		.activity-table thead {
			background: #f5f7fa;
		}

		.activity-table th,
		.activity-table td {
			border: 1px solid #ddd;
			padding: 10px;
			vertical-align: top;
		}

		.activity-table th {
			font-weight: 600;
			text-align: left;
		}

		.activity-table tbody tr {
			transition: background 0.2s;
		}

		.activity-table tbody tr:hover {
			background: #f0f4ff;
		}

		.text-wrap {
			max-width: 280px;
			word-break: break-word;
		}

		/* Badges */
		.badge {
			padding: 4px 8px;
			border-radius: 12px;
			font-size: 12px;
		}

		.badge-success {
			background: #28a745;
			color: white;
		}

		.badge-pending {
			background: #6c757d;
			color: white;
		}

		/* Action buttons */
		.actions {
			display: flex;
			gap: 6px;
		}

		.btn {
			padding: 5px 10px;
			font-size: 12px;
			border-radius: 4px;
			text-decoration: none;
			cursor: pointer;
		}

		.btn-edit {
			background: #ffc107;
			color: #000;
			border: none;
		}

		.btn-edit:hover {
			background: #e0a800;
		}

		.btn-delete {
			background: #dc3545;
			color: #fff;
			border: none;
		}

		.btn-delete:hover {
			background: #c82333;
		}

		/* Inline edit form */
		.inline-edit-form {
			background: #f8f9fa;
			padding: 15px;
			border-radius: 10px;
			border: 1px solid #d1d5db;
		}

		.inline-edit-form textarea {
			width: 100%;
			padding: 10px;
			font-size: 13px;
			border-radius: 6px;
			border: 1px solid #ccc;
		}

		.inline-edit-form .form-actions {
			display: flex;
			gap: 10px;
			justify-content: flex-end;
			margin-top: 10px;
		}

		.btn-cancel {
			background: #6c757d;
			color: #fff;
		}

		.btn-cancel:hover {
			background: #5a6268;
		}
	</style>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	 <script>
	function toggleEditActivity(id) {
    const viewRow = document.getElementById('view-activity-' + id);
    const editRow = document.getElementById('edit-activity-' + id);
    if (editRow.style.display === 'none') {
        editRow.style.display = '';
        viewRow.style.display = 'none';
    } else {
        editRow.style.display = 'none';
        viewRow.style.display = '';
    }
}
function toggleEdit(id) {
    const viewRow = document.getElementById('view-row-' + id);
    const editRow = document.getElementById('edit-row-' + id);
    if (editRow.style.display === 'none') {
        editRow.style.display = '';
        viewRow.style.display = 'none';
    } else {
        editRow.style.display = 'none';
        viewRow.style.display = '';
    }
}
	</script>

{% endblock %}

{% block body %}
<div class="activity-page">
    <div class="container">

        <div class="challenge-card">
            <div class="challenge-header">
                <h3>📚 Historique des activités</h3>
            </div>

            <p class="challenge-desc">
                Consultez vos anciennes activités ainsi que leur évaluation.
            </p>

            <div class="activity-form">
                <h4>📝 Activités soumises</h4>

                <table class="activity-history-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Activité</th>
                            <th>Description</th>
                            <th>Fichier</th>
                            <th>État</th>
                            <th>Note</th>
                            <th>Feedback</th>
                            <th>Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>1</td>

                            <td>
                                <strong>Analyse UX</strong><br>
                                <small>Challenge Design Thinking</small>
                            </td>

                            <td class="text-wrap">
                                Analyse complète de l’expérience utilisateur avec propositions
                                d’amélioration sur le parcours client.
                            </td>

                            <td>
                                <a href="#">📎 Voir</a>
                            </td>

                            <td>
                                <span class="status validated">✔ Validée</span>
                            </td>

                            <td>
                                17 / 20
                            </td>

                            <td class="text-wrap">
                                Travail bien structuré et très pertinent.
                            </td>

                            <td>
                                12/01/2026
                            </td>
                        </tr>

                        <tr>
                            <td>2</td>

                            <td>
                                <strong>Audit sécurité</strong><br>
                                <small>Challenge Cyber</small>
                            </td>

                            <td class="text-wrap">
                                Identification des failles et proposition de correctifs.
                            </td>

                            <td>
                                —
                            </td>

                            <td>
                                <span class="status pending">⏳ En attente</span>
                            </td>

                            <td>
                                —
                            </td>

                            <td class="text-wrap">
                                —
                            </td>

                            <td>
                                05/01/2026
                            </td>
                        </tr>

                        <tr>
                            <td>3</td>

                            <td>
                                <strong>Étude de marché</strong><br>
                                <small>Challenge Business</small>
                            </td>

                            <td class="text-wrap">
                                Étude complète du marché cible et analyse concurrentielle.
                            </td>

                            <td>
                                <a href="#">📎 Voir</a>
                            </td>

                            <td>
                                <span class="status rejected">✖ Refusée</span>
                            </td>

                            <td>
                                9 / 20
                            </td>

                            <td class="text-wrap">
                                Analyse intéressante mais manque de données chiffrées.
                            </td>

                            <td>
                                28/12/2025
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>

    </div>
</div>
	{% endblock %}
