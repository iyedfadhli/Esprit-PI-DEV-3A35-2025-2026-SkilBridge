{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}
	<link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

	{% block stylesheets %}
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/home/home_page.css') }}">
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/user/auth.css') }}">
		<style>
			.otp-container {
				display: flex;
				justify-content: center;
				align-items: center;
				min-height: 70vh;
				padding: 40px 20px;
			}
			.otp-card {
				background: #fff;
				border-radius: 16px;
				box-shadow: 0 8px 32px rgba(0,0,0,0.10);
				padding: 48px 40px;
				max-width: 460px;
				width: 100%;
				text-align: center;
			}
			.otp-card h2 {
				font-size: 24px;
				font-weight: 700;
				color: #1f2937;
				margin-bottom: 8px;
			}
			.otp-card .subtitle {
				color: #6b7280;
				font-size: 14px;
				margin-bottom: 32px;
				line-height: 1.5;
			}
			.otp-card .form-group {
				text-align: left;
				margin-bottom: 20px;
			}
			.otp-card .form-group label {
				display: block;
				font-size: 14px;
				font-weight: 600;
				color: #374151;
				margin-bottom: 6px;
			}
			.otp-card .form-group input {
				width: 100%;
				padding: 12px 16px;
				border: 2px solid #e5e7eb;
				border-radius: 10px;
				font-size: 15px;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
				box-sizing: border-box;
			}
			.otp-card .form-group input:focus {
				border-color: #6366f1;
				box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
			}
			.otp-card .primary-btn {
				width: 100%;
				padding: 14px;
				font-size: 16px;
				font-weight: 600;
				border: none;
				border-radius: 10px;
				cursor: pointer;
				background: linear-gradient(135deg, #6366f1, #8b5cf6);
				color: #fff;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			.otp-card .primary-btn:hover {
				transform: translateY(-1px);
				box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
			}
			.back-link {
				display: inline-block;
				margin-top: 20px;
				color: #6366f1;
				text-decoration: none;
				font-size: 14px;
				font-weight: 600;
			}
			.back-link:hover { text-decoration: underline; }
			.alert { padding: 12px 16px; margin-bottom: 20px; border-radius: 8px; font-size: 14px; text-align: left; }
			.alert-error { background-color: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
			.alert-success { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
			.alert-warning { background-color: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
			.icon-circle {
				width: 64px; height: 64px; border-radius: 50%;
				background: linear-gradient(135deg, #6366f1, #8b5cf6);
				display: flex; align-items: center; justify-content: center;
				margin: 0 auto 20px;
			}
			.icon-circle svg { width: 32px; height: 32px; fill: #fff; }
		</style>
	{% endblock %}

	{% block javascripts %}{% endblock %}

	<div class="otp-container">
		<div class="otp-card">

			<div class="icon-circle">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg>
			</div>

			<h2>Forgot Password?</h2>
			<p class="subtitle">
				Enter your email address and we'll send you a verification code to reset your password.
			</p>

			{# Flash Messages #}
			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ label }}">{{ message }}</div>
				{% endfor %}
			{% endfor %}

			<form method="POST" action="{{ path('forgot_password') }}">
				<div class="form-group">
					<label for="email">Email Address</label>
					<input type="email" name="email" id="email" placeholder="you@example.com" value="{{ email|default('') }}" required autofocus>
				</div>
				<button type="submit" class="primary-btn">Send Verification Code</button>
			</form>

			<a href="{{ path('sign') }}" class="back-link">← Back to Login</a>
		</div>
	</div>
{% endblock %}
