{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Sign In / Sign Up{% endblock %}

{% block body %}
	<link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

	{% block stylesheets %}
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/home/home_page.css') }}">
		<link rel="stylesheet" href="{{asset('assets/css/frontoffice/user/auth.css')}}">
        <style>
            .alert { padding: 10px; margin-bottom: 15px; border-radius: 5px; font-size: 14px; }
            .alert-error { background-color: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
            .alert-success { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
            .form-error { color: #dc2626; font-size: 13px; margin-top: 5px; }
        </style>
	{% endblock %}
	{% block javascripts %}
		 <script src="{{ asset('assets/js/frontoffice/user_sign.js') }}" defer></script>
	{% endblock %}

	<div class="auth-container">
		<div class="auth-card">

            {# Flash Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

			<div class="auth-tabs">
				<button class="tab active" id="loginTab">Existing User</button>
				<button class="tab" id="registerTab">New User</button>
			</div>


			{{ form_start(form, {'attr': {'class': 'auth-form active', 'id': 'loginForm', 'novalidate': 'novalidate'}}) }}
			<h2>Welcome Back 👋</h2>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                <div class="form-error">{{ form_errors(form.email) }}</div>
            </div>

            <div class="form-group">
                {{ form_label(form.password) }}
                {{ form_widget(form.password) }}
                <div class="form-error">{{ form_errors(form.password) }}</div>
            </div>

			<div class="form-row">
				<label class="checkbox">
					<input type="checkbox" name="remember">
					<span>Keep me signed in</span>
				</label>
				<a href="#" class="forgot-link">Forgot password?</a>
			</div>

			<button type="submit" class="primary-btn">Login</button>

			{{ form_end(form) }}

			<form class="auth-form" id="registerForm" method="POST">
				<h2>Create Account 🚀</h2>
				    <input type="hidden" name="register_submit" value="1">


				<label>Account Type</label>
				<select name="type" id="userType">
					<option value="">-- Select Type --</option>
					<option value="student" {{ registerData.type|default('') == 'student' ? 'selected' : '' }}>Student</option>
					<option value="supervisor" {{ registerData.type|default('') == 'supervisor' ? 'selected' : '' }}>Supervisor</option>
					<option value="entreprise" {{ registerData.type|default('') == 'entreprise' ? 'selected' : '' }}>Entreprise</option>
				</select>
                {% if registerErrors.type is defined %}
                    <div class="form-error">{{ registerErrors.type }}</div>
                {% endif %}

				<div id="prenomDiv">
					<label>First Name</label>
					<input type="text" name="prenom" placeholder="Your first name" value="{{ registerData.prenom|default('') }}">
                    {% if registerErrors.prenom is defined %}
                        <div class="form-error">{{ registerErrors.prenom }}</div>
                    {% endif %}
				</div>

				<label>Last Name / Company Name</label>
				<input type="text" name="nom" placeholder="Your last name or company name" value="{{ registerData.nom|default('') }}">
                {% if registerErrors.nom is defined %}
                    <div class="form-error">{{ registerErrors.nom }}</div>
                {% endif %}

				<div id="dobDiv">
					<label>Date of Birth</label>
					<input type="date" name="date_naissance" value="{{ registerData.date_naissance|default('') }}">
				</div>

				<label>Email</label>
				<input type="text" name="email" placeholder="you@example.com" value="{{ registerData.email|default('') }}">
                {% if registerErrors.email is defined %}
                    <div class="form-error">{{ registerErrors.email }}</div>
                {% endif %}

				<div id="domaineDiv" style="display: none;">
					<label>Company Domain</label>
					<input type="text" name="domaine" placeholder="Your company domain or industry" value="{{ registerData.domaine|default('') }}">
                    {% if registerErrors.domaine is defined %}
                        <div class="form-error">{{ registerErrors.domaine }}</div>
                    {% endif %}
				</div>

				<label>Password</label>
				<input type="password" name="passwd" placeholder="Choose a password">
                {% if registerErrors.passwd is defined %}
                    <div class="form-error">{{ registerErrors.passwd }}</div>
                {% endif %}

				<button type="submit" class="primary-btn">Register</button>
			</form>
            
            {% if showRegister is defined and showRegister %}
             <script>
                document.addEventListener('DOMContentLoaded', function() {
                    document.getElementById('registerTab').click();
                });
             </script>
            {% endif %}

		</div>
	</div>
{% endblock %}
