{% block body %}
	<link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

	{% block stylesheets %}
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/home/home_page.css') }}">

		<link rel="stylesheet" href="{{asset('assets/css/frontoffice/user/auth.css')}}">

	{% endblock %}
	{% block javascripts %}
		 <script src="{{ asset('assets/js/frontoffice/user_sign.js') }}" defer></script>
	{% endblock %}

	<div class="auth-container">
		<div class="auth-card">

			<div class="auth-tabs">
				<button class="tab active" id="loginTab">Existing User</button>
				<button class="tab" id="registerTab">New User</button>
			</div>


			{{ form_start(form, {'attr': {'class': 'auth-form active', 'id': 'loginForm'}}) }}
			<h2>Welcome Back 👋</h2>

			{{ form_row(form.email) }}
			{{ form_row(form.password) }}

			<div class="form-row">
				<label class="checkbox">
					<input type="checkbox" name="remember">
					<span>Keep me signed in</span>
				</label>
				<a href="#" class="forgot-link">Forgot password?</a>
			</div>

			<button type="submit" class="primary-btn">Login</button>

			{{ form_end(form) }}
			<form class="auth-form" id="registerForm" method="POST">
				<h2>Create Account 🚀</h2>
				    <input type="hidden" name="register_submit" value="1">


				<label>Account Type</label>
				<select name="type" id="userType" required>
					<option value="">-- Select Type --</option>
					<option value="student">Student</option>
					<option value="supervisor">Supervisor</option>
					<option value="entreprise">Entreprise</option>
				</select>

				<div id="prenomDiv">
					<label>First Name</label>
					<input type="text" name="prenom" placeholder="Your first name">
				</div>

				<label>Last Name / Company Name</label>
				<input type="text" name="nom" placeholder="Your last name or company name" required>

				<div id="dobDiv">
					<label>Date of Birth</label>
					<input type="date" name="date_naissance">
				</div>

				<label>Email</label>
				<input type="email" name="email" placeholder="you@example.com" required>

				<div id="domaineDiv" style="display: none;">
					<label>Company Domain</label>
					<input type="text" name="domaine" placeholder="Your company domain or industry">
				</div>

				<label>Password</label>
				<input type="password" name="passwd" placeholder="Choose a password" required>

				<button type="submit" class="primary-btn">Register</button>
			</form>

		</div>
	</div>
{% endblock %}
