{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Reset Password{% endblock %}

{% block body %}
	<link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

	{% block stylesheets %}
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/home/home_page.css') }}">
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/user/auth.css') }}">
		<style>
			.otp-container {
				display: flex;
				justify-content: center;
				align-items: center;
				min-height: 70vh;
				padding: 40px 20px;
			}
			.otp-card {
				background: #fff;
				border-radius: 16px;
				box-shadow: 0 8px 32px rgba(0,0,0,0.10);
				padding: 48px 40px;
				max-width: 460px;
				width: 100%;
				text-align: center;
			}
			.otp-card h2 { font-size: 24px; font-weight: 700; color: #1f2937; margin-bottom: 8px; }
			.otp-card .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; line-height: 1.5; }
			.otp-card .form-group {
				text-align: left;
				margin-bottom: 20px;
			}
			.otp-card .form-group label {
				display: block;
				font-size: 14px;
				font-weight: 600;
				color: #374151;
				margin-bottom: 6px;
			}
			.otp-card .form-group input {
				width: 100%;
				padding: 12px 16px;
				border: 2px solid #e5e7eb;
				border-radius: 10px;
				font-size: 15px;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
				box-sizing: border-box;
			}
			.otp-card .form-group input:focus {
				border-color: #6366f1;
				box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
			}
			.otp-card .primary-btn {
				width: 100%; padding: 14px; font-size: 16px; font-weight: 600; border: none; border-radius: 10px;
				cursor: pointer; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff;
				transition: transform 0.15s, box-shadow 0.15s; margin-top: 8px;
			}
			.otp-card .primary-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3); }
			.alert { padding: 12px 16px; margin-bottom: 20px; border-radius: 8px; font-size: 14px; text-align: left; }
			.alert-error { background-color: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
			.alert-success { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
			.icon-circle {
				width: 64px; height: 64px; border-radius: 50%;
				background: linear-gradient(135deg, #10b981, #059669);
				display: flex; align-items: center; justify-content: center;
				margin: 0 auto 20px;
			}
			.icon-circle svg { width: 32px; height: 32px; fill: #fff; }
			.form-error { color: #dc2626; font-size: 13px; margin-top: 5px; }
		</style>
	{% endblock %}

	{% block javascripts %}{% endblock %}

	<div class="otp-container">
		<div class="otp-card">

			<div class="icon-circle">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
			</div>

			<h2>Set New Password</h2>
			<p class="subtitle">
				Create a new password for your account.<br>
				Make sure it's at least 6 characters long.
			</p>

			{# Flash Messages #}
			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ label }}">{{ message }}</div>
				{% endfor %}
			{% endfor %}

			<form method="POST" action="{{ path('forgot_password_reset') }}">
				<div class="form-group">
					<label for="password">New Password</label>
					<input type="password" name="password" id="password" placeholder="Enter new password" required autofocus>
				</div>
				<div class="form-group">
					<label for="confirm_password">Confirm Password</label>
					<input type="password" name="confirm_password" id="confirm_password" placeholder="Confirm new password" required>
				</div>
				<button type="submit" class="primary-btn">Reset Password</button>
			</form>
		</div>
	</div>
{% endblock %}
