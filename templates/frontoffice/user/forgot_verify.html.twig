{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Verify Code{% endblock %}

{% block body %}
	<link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

	{% block stylesheets %}
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/home/home_page.css') }}">
		<link rel="stylesheet" href="{{ asset('assets/css/frontoffice/user/auth.css') }}">
		<style>
			.otp-container {
				display: flex;
				justify-content: center;
				align-items: center;
				min-height: 70vh;
				padding: 40px 20px;
			}
			.otp-card {
				background: #fff;
				border-radius: 16px;
				box-shadow: 0 8px 32px rgba(0,0,0,0.10);
				padding: 48px 40px;
				max-width: 460px;
				width: 100%;
				text-align: center;
			}
			.otp-card h2 { font-size: 24px; font-weight: 700; color: #1f2937; margin-bottom: 8px; }
			.otp-card .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; line-height: 1.5; }
			.otp-card .subtitle strong { color: #6366f1; }
			.otp-inputs { display: flex; justify-content: center; gap: 10px; margin-bottom: 28px; }
			.otp-inputs input {
				width: 52px; height: 58px; text-align: center; font-size: 24px; font-weight: 700;
				border: 2px solid #e5e7eb; border-radius: 12px; outline: none;
				transition: border-color 0.2s, box-shadow 0.2s; color: #1f2937; background: #f9fafb;
			}
			.otp-inputs input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15); background: #fff; }
			.otp-inputs input.error { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12); }
			.otp-card .primary-btn {
				width: 100%; padding: 14px; font-size: 16px; font-weight: 600; border: none; border-radius: 10px;
				cursor: pointer; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			.otp-card .primary-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3); }
			.resend-row { margin-top: 20px; font-size: 14px; color: #6b7280; }
			.alert { padding: 12px 16px; margin-bottom: 20px; border-radius: 8px; font-size: 14px; text-align: left; }
			.alert-error { background-color: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
			.alert-success { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
			.alert-warning { background-color: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
			.icon-circle {
				width: 64px; height: 64px; border-radius: 50%;
				background: linear-gradient(135deg, #6366f1, #8b5cf6);
				display: flex; align-items: center; justify-content: center;
				margin: 0 auto 20px;
			}
			.icon-circle svg { width: 32px; height: 32px; fill: #fff; }
		</style>
	{% endblock %}

	{% block javascripts %}{% endblock %}

	<div class="otp-container">
		<div class="otp-card">

			<div class="icon-circle">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 2-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
			</div>

			<h2>Enter Verification Code</h2>
			<p class="subtitle">
				We sent a 6-digit code to<br>
				<strong>{{ email }}</strong>
			</p>

			{# Flash Messages #}
			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ label }}">{{ message }}</div>
				{% endfor %}
			{% endfor %}

			{% if fallback_code is defined and fallback_code %}
				<div style="background: #fef3c7; border: 2px solid #f59e0b; border-radius: 10px; padding: 16px; margin-bottom: 24px;">
					<p style="margin: 0 0 8px; font-size: 13px; color: #92400e; font-weight: 600;">⚠️ Email non envoyé — voici votre code :</p>
					<div style="font-size: 32px; font-weight: 800; letter-spacing: 10px; color: #1f2937;">{{ fallback_code }}</div>
				</div>
			{% endif %}

			<form method="POST" action="{{ path('forgot_password_verify') }}" id="otpForm">
				<div class="otp-inputs">
					<input type="text" maxlength="1" class="otp-digit" autofocus inputmode="numeric" pattern="[0-9]">
					<input type="text" maxlength="1" class="otp-digit" inputmode="numeric" pattern="[0-9]">
					<input type="text" maxlength="1" class="otp-digit" inputmode="numeric" pattern="[0-9]">
					<input type="text" maxlength="1" class="otp-digit" inputmode="numeric" pattern="[0-9]">
					<input type="text" maxlength="1" class="otp-digit" inputmode="numeric" pattern="[0-9]">
					<input type="text" maxlength="1" class="otp-digit" inputmode="numeric" pattern="[0-9]">
				</div>
				<input type="hidden" name="otp_code" id="otpHidden">
				<button type="submit" class="primary-btn" id="verifyBtn">Verify Code</button>
			</form>

			<div class="resend-row">
				Didn't receive the code?
				<form method="POST" action="{{ path('forgot_password_resend') }}" style="display:inline">
					<button type="submit" id="resendLink" style="background:none;border:none;color:#6366f1;font-weight:600;cursor:pointer;font-size:14px;padding:0;">
						Resend Code
					</button>
				</form>
				<span id="cooldownTimer" style="display:none; color:#9ca3af;"></span>
			</div>
		</div>
	</div>

	<script>
	document.addEventListener('DOMContentLoaded', function() {
		const digits = document.querySelectorAll('.otp-digit');
		const hidden = document.getElementById('otpHidden');
		const form = document.getElementById('otpForm');
		const resendBtn = document.getElementById('resendLink');
		const cooldown = document.getElementById('cooldownTimer');

		digits.forEach((input, idx) => {
			input.addEventListener('input', function() {
				this.value = this.value.replace(/[^0-9]/g, '');
				if (this.value && idx < digits.length - 1) digits[idx + 1].focus();
				updateHidden();
			});
			input.addEventListener('keydown', function(e) {
				if (e.key === 'Backspace' && !this.value && idx > 0) digits[idx - 1].focus();
			});
			input.addEventListener('paste', function(e) {
				e.preventDefault();
				const data = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
				for (let i = 0; i < data.length && i < digits.length; i++) digits[i].value = data[i];
				if (data.length > 0) digits[Math.min(data.length, digits.length) - 1].focus();
				updateHidden();
			});
		});

		function updateHidden() { hidden.value = Array.from(digits).map(d => d.value).join(''); }

		form.addEventListener('submit', function(e) {
			updateHidden();
			if (hidden.value.length !== 6) {
				e.preventDefault();
				digits.forEach(d => d.classList.add('error'));
				setTimeout(() => digits.forEach(d => d.classList.remove('error')), 1500);
			}
		});

		let remaining = 60;
		function startCooldown() {
			resendBtn.style.display = 'none';
			cooldown.style.display = 'inline';
			const interval = setInterval(() => {
				cooldown.textContent = 'Resend in ' + remaining + 's';
				remaining--;
				if (remaining < 0) {
					clearInterval(interval);
					resendBtn.style.display = 'inline';
					cooldown.style.display = 'none';
					remaining = 60;
				}
			}, 1000);
		}
		startCooldown();
	});
	</script>
{% endblock %}
