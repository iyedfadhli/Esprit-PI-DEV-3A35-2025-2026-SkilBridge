{% extends 'frontoffice/base_front.html.twig' %}


{% block body %}

	<section class="hero">
		<div class="hero-left">
			<h1 class="hero-title">Skill Bridge</h1>
			<p class="hero-subtitle">
				Plateforme éducative intelligente pour développer vos compétences et booster votre carrière.
			</p>
            
		</div>
        
		<div class="hero-right">
			<img src="{{ asset('assets/images/frontoffice/home_pic.jpg') }}" alt="Skill Bridge illustration">
		</div>
	</section>
	

	<section class="modules">
		<div class="module-card" id="profile">
			<div class="module-icon">👤</div>
			<h3>Profile</h3>
			<p>Gérez vos informations et suivez votre progression.</p>
		</div>

		<div class="module-card" id="courses">
			<div class="module-icon">📚</div>
			<h3>Courses</h3>
			<p>Accédez à des cours interactifs pour développer vos compétences.</p>
		</div>

		<div class="module-card" id="groups">
			<div class="module-icon">👥</div>
			<h3>Groups</h3>
			<p>Rejoignez des groupes d’étude et collaborez avec d’autres étudiants.</p>
		</div>

		<div class="module-card" id="challenges">
			<div class="module-icon">🏆</div>
			<h3>Challenges</h3>
			<p>Testez vos compétences grâce à des défis interactifs.</p>
		</div>

		<div class="module-card" id="cv-internship">
			<div class="module-icon">📄</div>
			<h3>CV & Internship</h3>
			<p>Créez votre CV et postulez pour des stages adaptés.</p>
		</div>

		<div class="module-card" id="hackathon">
			<div class="module-icon">💡</div>
			<h3>Hackathon</h3>
			<p>Participez à des hackathons et mettez vos compétences en pratique.</p>
		</div>
	</section>

	<section class="about-section">
