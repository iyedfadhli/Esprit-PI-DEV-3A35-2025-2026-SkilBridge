{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Hackathons - Skill Bridge{% endblock %}

{% block stylesheets %}
<style>
    /* Existing Styles */
    .hackathon-header {
        background: linear-gradient(135deg, #6c5ce7, #a29bfe);
        color: white;
        text-align: center;
        padding: 60px 20px;
        margin-bottom: 40px;
        border-radius: 0 0 20px 20px;
    }
    .hackathon-header h1 {
        font-size: 3em;
        font-weight: 800;
        margin-bottom: 15px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }
    .hackathon-header p {
        font-size: 1.2em;
        opacity: 0.9;
    }
    .hackathons-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 30px;
        padding: 0 40px 60px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .hackathon-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }
    .hackathon-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.12);
    }
    .card-img-wrapper {
        position: relative;
        height: 200px;
        background: #f0f0f0;
    }
    .card-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .card-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(0,0,0,0.6);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85em;
        backdrop-filter: blur(5px);
    }
    .card-body {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    .card-title {
        font-size: 1.4em;
        font-weight: 700;
        margin: 0 0 10px;
        color: #2d3436;
    }
    .card-info {
        margin-bottom: 20px;
        color: #636e72;
        font-size: 0.95em;
    }
    .info-item {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }
    .info-item i {
        width: 25px;
        color: #6c5ce7;
    }
    .sponsors-section {
        margin-top: auto;
        padding-top: 15px;
        border-top: 1px solid #eee;
    }
    .sponsors-label {
        font-size: 0.8em;
        text-transform: uppercase;
        color: #b2bec3;
        font-weight: 700;
        margin-bottom: 8px;
        display: block;
    }
    .sponsors-list {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }
    .sponsor-logo {
        height: 30px;
        width: auto;
        background: #fdfdfd; 
        border: 1px solid #eee;
        border-radius: 5px;
        padding: 2px 5px;
    }
    .btn-participate {
        display: block;
        width: 100%;
        padding: 12px;
        background: linear-gradient(45deg, #6c5ce7, #a29bfe);
        color: white;
        text-align: center;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 15px;
        transition: opacity 0.3s;
        border: none;
        cursor: pointer;
    }
    .btn-participate:hover {
        opacity: 0.9;
        text-decoration: none;
        color: white;
    }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }
    .modal-content {
        background: white;
        padding: 40px;
        border-radius: 25px;
        max-width: 800px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        position: relative;
        box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        animation: modalFadeIn 0.4s ease;
    }
    @keyframes modalFadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .modal-close {
        position: absolute;
        top: 20px;
        right: 25px;
        font-size: 24px;
        cursor: pointer;
        color: #aaa;
    }
    .tips-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }
    .tip-card {
        background: #f8faff;
        border: 1px solid #e1e7ff;
        padding: 20px;
        border-radius: 15px;
        transition: scale 0.3s;
    }
    .tip-card:hover { transform: scale(1.02); background: #fff; border-color: #6c5ce7; }
    .tip-card h3 { font-size: 1.1em; color: #6c5ce7; margin-bottom: 10px; }
    .tip-card p { font-size: 0.9em; color: #555; line-height: 1.4; }
    
    .loading-spinner {
        text-align: center;
        padding: 40px;
    }
    .loading-spinner i {
        font-size: 3em;
        color: #6c5ce7;
        animation: spin 1s infinite linear;
    }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
{% endblock %}

{% block body %}
    <div class="hackathon-header">
        <h1>Discover Hackathons</h1>
        <p>Join the best coding competitions and showcase your skills.</p>
    </div>

    <div class="hackathons-grid">
        {% for hackathon in hackathons %}
            <div class="hackathon-card">
                <div class="card-img-wrapper">
                    <img src="{{ hackathon.coverUrl }}" alt="{{ hackathon.title }}">
                    <div class="card-badge">
                        {{ hackathon.fee > 0 ? hackathon.fee ~ ' TND' : 'Free' }}
                    </div>
                </div>
                
                <div class="card-body">
                    <h2 class="card-title">{{ hackathon.title }}</h2>
                    <div class="card-info">
                        <div class="info-item">
                            <i class="fa fa-calendar"></i>
                            <span>{{ hackathon.startAt|date("M d, Y") }}</span>
                        </div>
                        <div class="info-item">
                            <i class="fa fa-map-marker"></i>
                            <span>{{ hackathon.location }}</span>
                        </div>
                        <div class="info-item">
                            <i class="fa fa-users"></i>
                            <span>Max {{ hackathon.maxTeams }} Teams</span>
                        </div>
                    </div>

                    <div class="sponsors-section">
                        <span class="sponsors-label">Sponsored By</span>
                        <div class="sponsors-list">
                            {% for sh in hackathon.sponsorHackathons %}
                                <img src="{{ sh.sponsor.logoUrl }}" alt="{{ sh.sponsor.name }}" class="sponsor-logo" title="{{ sh.sponsor.name }}">
                            {% else %}
                                <span style="font-size: 0.85em; color: #aaa;">No sponsors yet</span>
                            {% endfor %}
                        </div>
                    </div>

                    <button class="btn-participate btn-trigger-tips" 
                            data-id="{{ hackathon.id }}" 
                            data-title="{{ hackathon.title }}">Participate Now</button>
                </div>
            </div>
        {% else %}
            <div style="text-align: center; width: 100%; grid-column: 1/-1; padding: 50px;">
                <h3 style="color: #636e72;">No Hackathons available right now.</h3>
                <p>Check back later for new events!</p>
            </div>
        {% endfor %}
    </div>

    <!-- AI Tips & Participation Modal -->
    <div class="modal-overlay" id="tipsModal">
        <div class="modal-content">
            <span class="modal-close" onclick="closeModal()">&times;</span>
            <div id="modalStep1">
                <h2 style="color: #2d3436; margin-bottom: 10px;">Before you join <span id="modalHackathonTitle" style="color: #6c5ce7;"></span>...</h2>
                <p style="color: #636e72;">Here are some <i class="fa fa-magic"></i> AI-powered tips to help you succeed, generated just for you!</p>
                
                <div id="tipsContent" class="tips-container">
                    <div class="loading-spinner">
                        <i class="fa fa-refresh"></i>
                        <p style="margin-top: 15px;">Gemini is thinking...</p>
                    </div>
                </div>
                
                <div style="margin-top: 40px; text-align: center;">
                    <button id="btnConfirmParticipation" class="btn-participate" style="max-width: 300px; display: inline-block;">
                        I'm Ready! Participate Now
                    </button>
                </div>
            </div>
            
            <div id="modalStepSuccess" style="display: none; text-align: center; padding: 20px;">
                <div style="font-size: 5em; color: #2ecc71; margin-bottom: 20px;">
                    <i class="fa fa-check-circle"></i>
                </div>
                <h2>Success! You're in!</h2>
                <p style="margin-bottom: 30px; font-size: 1.1em; color: #636e72;">Would you like to add this hackathon to your Google Calendar so you don't miss it?</p>
                
                <div style="display: flex; gap: 15px; justify-content: center;">
                    <a id="btnGoogleCalendar" target="_blank" class="btn-participate" style="background: #ea4335;">
                        <i class="fa fa-calendar-plus-o"></i> Yes, Add to Calendar
                    </a>
                    <button onclick="closeModal()" class="btn-participate" style="background: #f1f2f6; color: #2d3436;">
                        Not now
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
    function initHackathonParticipation() {
        let currentHackathonId = null;

        const triggerBtns = document.querySelectorAll('.btn-trigger-tips');
        if (triggerBtns.length === 0) return;

        triggerBtns.forEach(btn => {
            // Remove existing listener if any to avoid duplicates
            btn.removeEventListener('click', handleTriggerClick);
            btn.addEventListener('click', handleTriggerClick);
        });

        function handleTriggerClick() {
            currentHackathonId = this.getAttribute('data-id');
            const title = this.getAttribute('data-title');
            
            document.getElementById('modalHackathonTitle').innerText = title;
            document.getElementById('tipsModal').style.display = 'flex';
            document.getElementById('modalStep1').style.display = 'block';
            document.getElementById('modalStepSuccess').style.display = 'none';
            
            fetchTips(currentHackathonId);
        }

        function fetchTips(id) {
            const container = document.getElementById('tipsContent');
            if (!container) return;
            container.innerHTML = `<div class="loading-spinner"><i class="fa fa-refresh"></i><p style="margin-top: 15px;">Gemini is thinking...</p></div>`;
            
            fetch(`/hackathon/${id}/tips`)
                .then(res => res.json())
                .then(data => {
                    if (data.error) throw new Error(data.error);
                    
                    container.innerHTML = '';
                    data.forEach(tip => {
                        const card = document.createElement('div');
                        card.className = 'tip-card';
                        card.innerHTML = `<h3>${tip.title}</h3><p>${tip.content}</p>`;
                        container.appendChild(card);
                    });
                })
                .catch(err => {
                    container.innerHTML = `<p style="color: #e74c3c;">Oops! Failed to get AI tips. But you've got this! ${err.message}</p>`;
                });
        }

        const confirmBtn = document.getElementById('btnConfirmParticipation');
        if (confirmBtn) {
            confirmBtn.removeEventListener('click', handleConfirmClick);
            confirmBtn.addEventListener('click', handleConfirmClick);
        }

        function handleConfirmClick() {
            this.innerHTML = '<i class="fa fa-refresh fa-spin"></i> Registering...';
            this.disabled = true;
            
            fetch(`/hackathon/${currentHackathonId}/participate`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('modalStep1').style.display = 'none';
                        document.getElementById('modalStepSuccess').style.display = 'block';
                        document.getElementById('btnGoogleCalendar').href = data.calendar_url;
                    } else {
                        alert('Error: ' + (data.error || 'Failed to participate'));
                        this.innerHTML = 'I\'m Ready! Participate Now';
                        this.disabled = false;
                    }
                })
                .catch(err => {
                    alert('Connection error');
                    this.innerHTML = 'I\'m Ready! Participate Now';
                    this.disabled = false;
                });
        }
    }

    // Initialize on both DOMContentLoaded and Turbo load
    document.addEventListener('DOMContentLoaded', initHackathonParticipation);
    document.addEventListener('turbo:load', initHackathonParticipation);

    function closeModal() {
        document.getElementById('tipsModal').style.display = 'none';
    }
</script>
{% endblock %}