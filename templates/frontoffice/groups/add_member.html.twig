<form method="get">
    <input type="text" name="q" placeholder="Search members by name">
    <button type="submit" class="btn btn-primary">Search</button>
</form>

{% if users %}
    <ul>
        {% for user in users %}
            <li>
                {{ user.username }}
                <a href="{{ path('group_add_member_confirm', {groupId: group.id, userId: user.id}) }}" class="btn btn-success btn-sm">Add</a>
            </li>
        {% endfor %}
    </ul>
{% endif %}