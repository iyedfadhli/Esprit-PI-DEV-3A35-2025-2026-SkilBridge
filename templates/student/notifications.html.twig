{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2 class="mb-3">Notifications</h2>
    {% if notifications is empty %}
        <div class="alert alert-info">You have no notifications.</div>
    {% else %}
        <ul class="list-group">
            {% for n in notifications %}
                <li class="list-group-item d-flex justify-content-between align-items-start {% if not n.isRead %}fw-bold{% endif %}">
                    <div class="ms-2 me-auto">
                        <div>{{ n.message }}</div>
                        <small class="text-muted">{{ n.createdAt ? n.createdAt|date('Y-m-d H:i') : '' }}</small>
                    </div>
                    {% if not n.isRead %}
                        <span class="badge bg-primary rounded-pill">New</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}

