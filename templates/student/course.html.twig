{% extends 'frontoffice/base_front.html.twig' %}

{% block title %}{{ course.title }} - Skill Bridge{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/frontoffice/student.css') }}">
    <style>
        .course-page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Course Header */
        .course-hero {
            background: var(--primary-gradient);
            border-radius: var(--radius-xl);
            padding: 3rem;
            color: white;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
        }

        .course-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 500px;
            height: 500px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
        }

        .course-hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: 5%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
        }

        .course-hero-content {
            position: relative;
            z-index: 1;
        }

        .course-breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 1rem;
        }

        .course-breadcrumb a {
            color: white;
            text-decoration: none;
        }

        .course-breadcrumb a:hover {
            text-decoration: underline;
        }

        .course-hero h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0 0 1rem 0;
        }

        .course-hero-description {
            font-size: 1.1rem;
            line-height: 1.6;
            opacity: 0.95;
            max-width: 700px;
            margin-bottom: 1.5rem;
        }

        .course-hero-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        .hero-meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.95rem;
        }

        .hero-meta-item i {
            opacity: 0.8;
        }

        /* Course Status Banner */
        .status-banner {
            background: white;
            border-radius: var(--radius-lg);
            padding: 1.5rem 2rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-md);
            flex-wrap: wrap;
            gap: 1rem;
        }

        .status-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .status-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .status-icon.locked {
            background: #fef3c7;
            color: #d97706;
        }

        .status-icon.progress {
            background: #dbeafe;
            color: #2563eb;
        }

        .status-icon.completed {
            background: #d1fae5;
            color: #059669;
        }

        .status-text h3 {
            margin: 0;
            font-size: 1.1rem;
            color: var(--text-primary);
        }

        .status-text p {
            margin: 0.25rem 0 0;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .status-action {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .status-action .btn-primary {
            background: var(--primary-gradient);
            color: white;
            padding: 0.875rem 1.75rem;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }

        .status-action .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .status-action .btn-download {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 0.875rem 1.75rem;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }

        .status-action .btn-download:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
        }

        /* Content Layout */
        .course-content-layout {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 2rem;
        }

        @media (max-width: 992px) {
            .course-content-layout {
                grid-template-columns: 1fr;
            }
        }

        /* Main Content */
        .course-main {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* Section Card */
        .section-card {
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            overflow: hidden;
        }

        .section-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-header h2 {
            margin: 0;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--text-primary);
        }

        .section-header h2 i {
            color: var(--primary);
        }

        .section-badge {
            background: var(--bg-tertiary);
            padding: 0.35rem 0.75rem;
            border-radius: var(--radius-full);
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .section-body {
            padding: 1.5rem;
        }

        /* Chapter List */
        .chapter-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .chapter-card {
            background: var(--bg-tertiary);
            border-radius: var(--radius-md);
            padding: 1.25rem 1.5rem;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        .chapter-card:hover {
            border-color: var(--border-color);
            box-shadow: var(--shadow-sm);
        }

        .chapter-card.completed {
            background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
            border-color: #a7f3d0;
        }

        .chapter-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .chapter-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .chapter-number {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        .chapter-card.completed .chapter-number {
            background: #10b981;
        }

        .chapter-title {
            margin: 0;
            font-size: 1.05rem;
            color: var(--text-primary);
        }

        .chapter-badge {
            padding: 0.35rem 0.75rem;
            border-radius: var(--radius-full);
            font-size: 0.75rem;
            font-weight: 600;
        }

        .chapter-badge.success {
            background: #d1fae5;
            color: #059669;
        }

        .chapter-badge.pending {
            background: #fef3c7;
            color: #d97706;
        }

        .chapter-content {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.6;
            margin-bottom: 1rem;
            padding-left: 52px;
        }

        .chapter-actions {
            padding-left: 52px;
            display: flex;
            gap: 0.75rem;
        }

        .btn-chapter {
            padding: 0.6rem 1.25rem;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }

        .btn-chapter.primary {
            background: var(--primary);
            color: white;
        }

        .btn-chapter.primary:hover {
            background: var(--primary-dark);
        }

        .btn-chapter.secondary {
            background: white;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
        }

        .btn-chapter.secondary:hover {
            background: var(--bg-tertiary);
        }

        .btn-chapter.success {
            background: #10b981;
            color: white;
        }

        /* Material Section */
        .material-container {
            border-radius: var(--radius-md);
            overflow: hidden;
            background: var(--bg-tertiary);
        }

        .material-container embed,
        .material-container video {
            width: 100%;
            display: block;
        }

        .material-container video {
            background: #000;
        }

        /* Sidebar */
        .course-sidebar {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Progress Card */
        .progress-card {
            background: white;
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            box-shadow: var(--shadow-md);
        }

        .progress-card h3 {
            margin: 0 0 1rem;
            font-size: 1rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .progress-card h3 i {
            color: var(--primary);
        }

        .progress-circle-container {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .progress-circle {
            position: relative;
            width: 140px;
            height: 140px;
        }

        .progress-circle svg {
            transform: rotate(-90deg);
        }

        .progress-circle-bg {
            fill: none;
            stroke: var(--bg-tertiary);
            stroke-width: 12;
        }

        .progress-circle-fill {
            fill: none;
            stroke: url(#progressGradient);
            stroke-width: 12;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.5s ease;
        }

        .progress-circle-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .progress-circle-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .progress-circle-label {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .progress-stats {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .progress-stat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
        }

        .progress-stat-label {
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .progress-stat-value {
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Final Quiz Card */
        .final-quiz-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            color: white;
        }

        .final-quiz-card h3 {
            margin: 0 0 0.75rem;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .final-quiz-card p {
            margin: 0 0 1rem;
            font-size: 0.9rem;
            opacity: 0.9;
            line-height: 1.5;
        }

        .final-quiz-card .btn-quiz {
            width: 100%;
            padding: 0.875rem;
            background: white;
            color: #667eea;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .final-quiz-card .btn-quiz:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        .final-quiz-card.locked {
            background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
        }

        .final-quiz-card.locked .btn-quiz {
            opacity: 0.7;
            cursor: not-allowed;
        }

        /* Review Alert */
        .review-alert {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            border-left: 4px solid #f59e0b;
        }

        .review-alert h3 {
            margin: 0 0 1rem;
            font-size: 1rem;
            color: #92400e;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .review-alert ul {
            margin: 0;
            padding-left: 1.5rem;
            color: #78350f;
        }

        .review-alert li {
            margin-bottom: 0.5rem;
            line-height: 1.5;
        }

        /* Flash Messages */
        .flash-messages {
            margin-bottom: 1.5rem;
        }

        .flash-message {
            padding: 1rem 1.5rem;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .flash-message.error {
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .flash-message.success {
            background: #d1fae5;
            color: #059669;
            border: 1px solid #a7f3d0;
        }

        @media (max-width: 768px) {
            .course-page {
                padding: 1rem;
            }

            .course-hero {
                padding: 2rem 1.5rem;
            }

            .course-hero h1 {
                font-size: 1.75rem;
            }

            .status-banner {
                flex-direction: column;
                text-align: center;
            }

            .status-info {
                flex-direction: column;
            }

            .chapter-content,
            .chapter-actions {
                padding-left: 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="course-page">
    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        <div class="flash-messages">
            {% for message in messages %}
                <div class="flash-message {{ label }}">
                    <i class="fa fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }}"></i>
                    {{ message }}
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    {# Course Hero #}
    <div class="course-hero">
        <div class="course-hero-content">
            <div class="course-breadcrumb">
                <a href="{{ path('student_dashboard') }}"><i class="fa fa-home"></i> Tableau de bord</a>
                <span>›</span>
                <span>{{ course.title }}</span>
            </div>
            <h1>{{ course.title }}</h1>
            {% if all_chapter_quizzes_passed %}
                <p class="course-hero-description">{{ course.description|default(course.content|striptags|slice(0, 200) ~ '...') }}</p>
            {% else %}
                <p class="course-hero-description">
                    <i class="fa fa-info-circle"></i>
                    Le résumé complet du cours et le quiz final seront débloqués après validation de tous les quiz de chapitres.
                </p>
            {% endif %}
            <div class="course-hero-meta">
                <span class="hero-meta-item">
                    <i class="fa fa-list"></i>
                    {{ chapters|length }} chapitres
                </span>
                <span class="hero-meta-item">
                    <i class="fa fa-clock-o"></i>
                    {{ course.duration|default(30) }} min
                </span>
                {% if course.creator %}
                    <span class="hero-meta-item">
                        <i class="fa fa-user"></i>
                        {{ course.creator.prenom|default('') }} {{ course.creator.nom|default('Formateur') }}
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

    {# Status Banner #}
    <div class="status-banner">
        <div class="status-info">
            {% if status == 'LOCKED' %}
                <div class="status-icon locked">
                    <i class="fa fa-lock"></i>
                </div>
                <div class="status-text">
                    <h3>Cours non démarré</h3>
                    <p>Inscrivez-vous pour accéder au contenu</p>
                </div>
            {% elseif status == 'IN_PROGRESS' %}
                <div class="status-icon progress">
                    <i class="fa fa-spinner"></i>
                </div>
                <div class="status-text">
                    <h3>Cours en cours</h3>
                    <p>Progression : {{ enrolment.progress|default(0) }}%</p>
                </div>
            {% else %}
                <div class="status-icon completed">
                    <i class="fa fa-check"></i>
                </div>
                <div class="status-text">
                    <h3>Cours terminé</h3>
                    <p>Score final : {{ enrolment.score|default('—') }}%</p>
                </div>
            {% endif %}
        </div>
        <div class="status-action">
            {% if status == 'LOCKED' %}
                <form method="post" action="{{ path('student_enrol_course', {'id': course.id}) }}">
                    <button type="submit" class="btn-primary">
                        <i class="fa fa-plus"></i> S'inscrire au cours
                    </button>
                </form>
            {% else %}
                {# PDF Download Button - visible for enrolled students #}
                <a href="{{ path('student_course_export_pdf', {'id': course.id}) }}" class="btn-download">
                    <i class="fa fa-file-pdf-o"></i> Télécharger PDF
                </a>
                {% if status == 'IN_PROGRESS' and all_chapter_quizzes_passed %}
                    {% set finalQuiz = course.quizzes|filter(q => q.chapter is null)|first %}
                    {% if finalQuiz %}
                        <a href="{{ path('student_quiz_attempt', {'quizId': finalQuiz.id}) }}" class="btn-primary">
                            <i class="fa fa-trophy"></i> Passer le quiz final
                        </a>
                    {% endif %}
                {% endif %}
            {% endif %}
        </div>
    </div>

    {# Content Layout #}
    <div class="course-content-layout">
        {# Main Content #}
        <div class="course-main">
            {# Material Section #}
            {% if course.material is not empty %}
                <div class="section-card">
                    <div class="section-header">
                        <h2><i class="fa fa-play-circle"></i> Ressource du cours</h2>
                    </div>
                    <div class="section-body">
                        <div class="material-container">
                            {% if course.material matches '/\\.pdf$/i' %}
                                <embed src="{{ asset('uploads/materials/' ~ course.material) }}" type="application/pdf" height="500px" />
                            {% elseif course.material matches '/\\.(mp4|webm)$/i' %}
                                <video controls>
                                    <source src="{{ asset('uploads/materials/' ~ course.material) }}" type="video/mp4">
                                    Votre navigateur ne supporte pas la lecture vidéo.
                                </video>
                            {% else %}
                                <a href="{{ course.material }}" target="_blank" class="btn-chapter primary">
                                    <i class="fa fa-external-link"></i> Accéder à la ressource
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Chapters Section #}
            {% if chapters is defined and chapters|length > 0 %}
                <div class="section-card">
                    <div class="section-header">
                        <h2><i class="fa fa-book"></i> Programme du cours</h2>
                        <span class="section-badge">{{ chapters|length }} chapitres</span>
                    </div>
                    <div class="section-body">
                        <div class="chapter-list">
                            {% set passedCount = 0 %}
                            {% for item in chapters %}
                                {% set chapter = item.chapter %}
                                {% if item.passed %}{% set passedCount = passedCount + 1 %}{% endif %}
                                <div class="chapter-card {{ item.passed ? 'completed' : '' }}">
                                    <div class="chapter-header">
                                        <div class="chapter-info">
                                            <div class="chapter-number">
                                                {% if item.passed %}
                                                    <i class="fa fa-check"></i>
                                                {% else %}
                                                    {{ loop.index }}
                                                {% endif %}
                                            </div>
                                            <h4 class="chapter-title">{{ chapter.title }}</h4>
                                        </div>
                                        {% if item.quiz %}
                                            {% if item.passed %}
                                                <span class="chapter-badge success">
                                                    <i class="fa fa-check"></i> Validé
                                                </span>
                                            {% else %}
                                                <span class="chapter-badge pending">
                                                    <i class="fa fa-clock-o"></i> À compléter
                                                </span>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                    <p class="chapter-content">
                                        {{ chapter.content|striptags|slice(0, 150) }}{% if chapter.content|length > 150 %}...{% endif %}
                                    </p>
                                    <div class="chapter-actions">
                                        {% if item.quiz %}
                                            {% if item.passed %}
                                                <a href="{{ path('student_quiz_result', {'attemptId': 1}) }}" class="btn-chapter secondary">
                                                    <i class="fa fa-eye"></i> Voir résultats
                                                </a>
                                                <a href="{{ path('student_quiz_attempt', {'quizId': item.quiz.id}) }}" class="btn-chapter secondary">
                                                    <i class="fa fa-refresh"></i> Refaire le quiz
                                                </a>
                                            {% else %}
                                                <a href="{{ path('student_quiz_attempt', {'quizId': item.quiz.id}) }}" class="btn-chapter primary">
                                                    <i class="fa fa-play"></i> Passer le quiz
                                                </a>
                                            {% endif %}
                                        {% else %}
                                            <span class="btn-chapter secondary" style="opacity: 0.6; cursor: default;">
                                                <i class="fa fa-info-circle"></i> Pas de quiz
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Sidebar #}
        <div class="course-sidebar">
            {# Progress Card #}
            {% if status != 'LOCKED' %}
                <div class="progress-card">
                    <h3><i class="fa fa-chart-pie"></i> Votre progression</h3>
                    
                    {% set totalChapters = chapters|length %}
                    {% set completedChapters = 0 %}
                    {% for item in chapters %}
                        {% if item.passed %}{% set completedChapters = completedChapters + 1 %}{% endif %}
                    {% endfor %}
                    {% set progressPercent = totalChapters > 0 ? ((completedChapters / totalChapters) * 100)|round : 0 %}
                    
                    <div class="progress-circle-container">
                        <div class="progress-circle">
                            <svg width="140" height="140" viewBox="0 0 140 140">
                                <defs>
                                    <linearGradient id="progressGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#667eea"/>
                                        <stop offset="100%" stop-color="#764ba2"/>
                                    </linearGradient>
                                </defs>
                                <circle class="progress-circle-bg" cx="70" cy="70" r="58"/>
                                <circle class="progress-circle-fill" cx="70" cy="70" r="58" 
                                        stroke-dasharray="364.42" 
                                        stroke-dashoffset="{{ 364.42 - (364.42 * progressPercent / 100) }}"/>
                            </svg>
                            <div class="progress-circle-text">
                                <span class="progress-circle-value">{{ progressPercent }}%</span>
                                <span class="progress-circle-label">Complété</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="progress-stats">
                        <div class="progress-stat">
                            <span class="progress-stat-label">
                                <i class="fa fa-check-circle" style="color: #10b981;"></i>
                                Chapitres validés
                            </span>
                            <span class="progress-stat-value">{{ completedChapters }}/{{ totalChapters }}</span>
                        </div>
                        <div class="progress-stat">
                            <span class="progress-stat-label">
                                <i class="fa fa-clock-o" style="color: #f59e0b;"></i>
                                Chapitres restants
                            </span>
                            <span class="progress-stat-value">{{ totalChapters - completedChapters }}</span>
                        </div>
                    </div>
                </div>

                {# Download Card #}
                <div class="progress-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white;">
                    <h3 style="color: white;"><i class="fa fa-download"></i> Téléchargement</h3>
                    <p style="font-size: 0.9rem; opacity: 0.95; margin-bottom: 1rem;">
                        Téléchargez ce cours en PDF pour étudier hors-ligne.
                    </p>
                    <a href="{{ path('student_course_export_pdf', {'id': course.id}) }}" 
                       class="btn-quiz" 
                       style="background: white; color: #059669;">
                        <i class="fa fa-file-pdf-o"></i> Télécharger PDF
                    </a>
                </div>
            {% endif %}

            {# Final Quiz Card #}
            {% set finalQuiz = course.quizzes|filter(q => q.chapter is null)|first %}
            {% if finalQuiz %}
                <div class="final-quiz-card {{ all_chapter_quizzes_passed ? '' : 'locked' }}">
                    <h3>
                        <i class="fa fa-trophy"></i>
                        Quiz Final
                    </h3>
                    {% if all_chapter_quizzes_passed %}
                        <p>Félicitations ! Vous avez complété tous les chapitres. Passez le quiz final pour valider le cours.</p>
                        <a href="{{ path('student_quiz_attempt', {'quizId': finalQuiz.id}) }}" class="btn-quiz">
                            <i class="fa fa-play"></i> Commencer le quiz
                        </a>
                    {% else %}
                        <p>Complétez tous les quiz de chapitres pour débloquer le quiz final.</p>
                        <span class="btn-quiz">
                            <i class="fa fa-lock"></i> Quiz verrouillé
                        </span>
                    {% endif %}
                </div>
            {% endif %}

            {# Review Alert #}
            {% if reviewSections is not empty %}
                <div class="review-alert">
                    <h3><i class="fa fa-lightbulb-o"></i> Sections à réviser</h3>
                    <ul>
                        {% for section in reviewSections %}
                            <li>{{ section }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
