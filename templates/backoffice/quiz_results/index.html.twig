{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Résultats des Quiz{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/backoffice/crud.css') }}">
{% endblock %}

{% block body %}
<div class="crud-container">
    <div class="crud-header">
        <div class="crud-header-content">
            <h1><i class="fas fa-chart-bar"></i> Résultats des Quiz</h1>
            <p class="crud-subtitle">Consultez les performances des étudiants sur chaque quiz</p>
        </div>
    </div>

    {% if quizStats|length > 0 %}
        <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            {% for item in quizStats %}
                <div class="stat-card" style="background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s ease;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="margin: 0; color: #333; font-size: 1.1rem;">{{ item.quiz.title }}</h3>
                        {% if item.quiz.course %}
                            <span class="badge badge-info" style="font-size: 0.75rem;">{{ item.quiz.course.title }}</span>
                        {% endif %}
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1.25rem;">
                        <div style="text-align: center; padding: 0.75rem; background: #f8fafc; border-radius: 8px;">
                            <div style="font-size: 1.5rem; font-weight: 700; color: #667eea;">{{ item.totalAttempts }}</div>
                            <div style="font-size: 0.8rem; color: #64748b;">Tentatives</div>
                        </div>
                        <div style="text-align: center; padding: 0.75rem; background: #f8fafc; border-radius: 8px;">
                            <div style="font-size: 1.5rem; font-weight: 700; color: #10b981;">{{ item.averageScore }}%</div>
                            <div style="font-size: 0.8rem; color: #64748b;">Moyenne</div>
                        </div>
                    </div>
                    
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.5rem;">
                            <span>Taux de réussite</span>
                            <span style="font-weight: 600;">{{ item.passRate }}%</span>
                        </div>
                        <div style="height: 8px; background: #fee2e2; border-radius: 4px; overflow: hidden;">
                            <div style="height: 100%; background: linear-gradient(90deg, #10b981, #34d399); width: {{ item.passRate }}%; transition: width 0.5s ease;"></div>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: #64748b; margin-top: 0.25rem;">
                            <span>{{ item.passedCount }} réussis</span>
                            <span>{{ item.totalAttempts - item.passedCount }} échoués</span>
                        </div>
                    </div>
                    
                    <a href="{{ path('admin_quiz_results_show', {quizId: item.quiz.id}) }}" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-eye"></i> Voir les détails
                    </a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <i class="fas fa-chart-pie"></i>
            <h3>Aucun quiz disponible</h3>
            <p>Créez des quiz pour voir les résultats des étudiants.</p>
            <a href="{{ path('admin_quiz_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Créer un quiz
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
