{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Détail de la tentative{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/backoffice/crud.css') }}">
    <style>
        .attempt-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem;
            border-radius: 16px;
            margin-bottom: 2rem;
        }
        
        .attempt-header h1 {
            margin: 0 0 0.5rem 0;
            font-size: 1.5rem;
        }
        
        .attempt-info {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            margin-top: 1.5rem;
        }
        
        .attempt-info-item {
            background: rgba(255,255,255,0.15);
            padding: 0.75rem 1.25rem;
            border-radius: 8px;
        }
        
        .attempt-info-item label {
            display: block;
            font-size: 0.8rem;
            opacity: 0.9;
            margin-bottom: 0.25rem;
        }
        
        .attempt-info-item span {
            font-size: 1.1rem;
            font-weight: 600;
        }
        
        .response-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            border: 1px solid #e5e7eb;
            transition: all 0.2s ease;
        }
        
        .response-card:hover {
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }
        
        .response-card.correct {
            border-left: 4px solid #10b981;
        }
        
        .response-card.incorrect {
            border-left: 4px solid #ef4444;
        }
        
        .response-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .question-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #f1f5f9;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .points-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .points-earned {
            background: #d1fae5;
            color: #059669;
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .points-lost {
            background: #fee2e2;
            color: #dc2626;
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .question-text {
            font-size: 1.1rem;
            color: #333;
            margin-bottom: 1rem;
            line-height: 1.6;
        }
        
        .answer-comparison {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        
        @media (max-width: 768px) {
            .answer-comparison {
                grid-template-columns: 1fr;
            }
        }
        
        .answer-box {
            padding: 1rem;
            border-radius: 8px;
        }
        
        .answer-box.student {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }
        
        .answer-box.correct-answer {
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
        }
        
        .answer-box-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.8rem;
            color: #64748b;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .answer-box-content {
            font-size: 1rem;
            color: #333;
        }
        
        .stats-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .stat-box {
            background: white;
            padding: 1.25rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        
        .stat-box-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #333;
        }
        
        .stat-box-label {
            font-size: 0.8rem;
            color: #64748b;
            margin-top: 0.25rem;
        }
        
        .stat-box.success .stat-box-value {
            color: #10b981;
        }
        
        .stat-box.danger .stat-box-value {
            color: #ef4444;
        }
        
        .stat-box.primary .stat-box-value {
            color: #667eea;
        }
    </style>
{% endblock %}

{% block body %}
<div class="crud-container">
    {# Breadcrumb #}
    <nav class="breadcrumb" style="margin-bottom: 1rem;">
        <a href="{{ path('admin_quiz_results_index') }}" style="color: #667eea; text-decoration: none;">
            <i class="fas fa-chart-bar"></i> Résultats
        </a>
        <span style="margin: 0 0.5rem; color: #94a3b8;">›</span>
        <a href="{{ path('admin_quiz_results_show', {quizId: attempt.quiz.id}) }}" style="color: #667eea; text-decoration: none;">
            {{ attempt.quiz.title }}
        </a>
        <span style="margin: 0 0.5rem; color: #94a3b8;">›</span>
        <span style="color: #64748b;">Tentative #{{ attempt.attemptNbr }}</span>
    </nav>

    {# Header #}
    <div class="attempt-header">
        <h1>
            <i class="fas fa-user-graduate"></i>
            {{ attempt.student.prenom|default('') }} {{ attempt.student.nom|default('Étudiant inconnu') }}
        </h1>
        <p style="opacity: 0.9; margin: 0;">{{ attempt.student.email|default('-') }}</p>
        
        <div class="attempt-info">
            <div class="attempt-info-item">
                <label>Quiz</label>
                <span>{{ attempt.quiz.title }}</span>
            </div>
            <div class="attempt-info-item">
                <label>Tentative</label>
                <span>#{{ attempt.attemptNbr }}</span>
            </div>
            <div class="attempt-info-item">
                <label>Score</label>
                <span>{{ attempt.score|round(1) }}%</span>
            </div>
            <div class="attempt-info-item">
                <label>Statut</label>
                <span>
                    {% if attempt.score >= (attempt.quiz.passingScore ?? 70) %}
                        ✅ Réussi
                    {% else %}
                        ❌ Échoué
                    {% endif %}
                </span>
            </div>
            <div class="attempt-info-item">
                <label>Date de soumission</label>
                <span>{{ attempt.submittedAt|date('d/m/Y à H:i') }}</span>
            </div>
        </div>
    </div>

    {# Stats Summary #}
    <div class="stats-summary">
        <div class="stat-box primary">
            <div class="stat-box-value">{{ stats.totalQuestions }}</div>
            <div class="stat-box-label">Questions</div>
        </div>
        <div class="stat-box success">
            <div class="stat-box-value">{{ stats.correctCount }}</div>
            <div class="stat-box-label">Correctes</div>
        </div>
        <div class="stat-box danger">
            <div class="stat-box-value">{{ stats.incorrectCount }}</div>
            <div class="stat-box-label">Incorrectes</div>
        </div>
        <div class="stat-box">
            <div class="stat-box-value">{{ stats.earnedPoints }}/{{ stats.totalPoints }}</div>
            <div class="stat-box-label">Points obtenus</div>
        </div>
    </div>

    {# Responses Detail #}
    <h2 style="margin-bottom: 1.5rem; color: #333;">
        <i class="fas fa-list-check" style="color: #667eea;"></i> Détail des réponses
    </h2>

    {% if responses|length > 0 %}
        {% for response in responses %}
            <div class="response-card {{ response.isCorrect ? 'correct' : 'incorrect' }}">
                <div class="response-header">
                    <span class="question-badge">
                        <i class="fas fa-question-circle" style="color: #667eea;"></i>
                        Question {{ loop.index }}
                    </span>
                    <div class="points-info">
                        {% if response.isCorrect %}
                            <span class="points-earned">
                                <i class="fas fa-check"></i> +{{ response.pointsEarned }} pts
                            </span>
                        {% else %}
                            <span class="points-lost">
                                <i class="fas fa-times"></i> 0/{{ response.question.point }} pts
                            </span>
                        {% endif %}
                    </div>
                </div>
                
                <div class="question-text">
                    {{ response.question.content }}
                </div>
                
                <div class="answer-comparison">
                    <div class="answer-box student">
                        <div class="answer-box-label">
                            <i class="fas fa-user"></i> Réponse de l'étudiant
                            {% if response.isCorrect %}
                                <i class="fas fa-check-circle" style="color: #10b981;"></i>
                            {% else %}
                                <i class="fas fa-times-circle" style="color: #ef4444;"></i>
                            {% endif %}
                        </div>
                        <div class="answer-box-content">
                            {{ response.selectedAnswer.content }}
                        </div>
                    </div>
                    
                    {% if not response.isCorrect %}
                        <div class="answer-box correct-answer">
                            <div class="answer-box-label">
                                <i class="fas fa-lightbulb" style="color: #059669;"></i> Bonne réponse
                            </div>
                            <div class="answer-box-content">
                                {% for answer in response.question.answers %}
                                    {% if answer.isCorrect %}
                                        {{ answer.content }}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="empty-state">
            <i class="fas fa-clipboard"></i>
            <h3>Aucune réponse enregistrée</h3>
            <p>Les réponses détaillées ne sont pas disponibles pour cette tentative.</p>
        </div>
    {% endif %}

    {# Actions #}
    <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
        <a href="{{ path('admin_quiz_results_show', {quizId: attempt.quiz.id}) }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour aux résultats
        </a>
    </div>
</div>
{% endblock %}
