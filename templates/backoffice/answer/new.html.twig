{% extends 'backoffice/base_back.html.twig' %}

{% block title %}New Answer - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <header class="admin-header">
        <h1><i class="fa-solid fa-plus"></i> Create New Answer</h1>
    </header>

    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_answer_index') }}">Answers</a>
        <span>/</span>
        <span>New</span>
    </nav>

    <div class="card">
        <div class="card-header">
            <h2><i class="fa-solid fa-check-double"></i> Answer Information</h2>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'crud-form', 'novalidate': 'novalidate'}}) }}
            
            <div class="form-group">
                {{ form_label(form.question, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.question) }}
                {% if form.question.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.question) }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.content) }}
                {% if form.content.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.content) }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <div class="form-check">
                    {{ form_widget(form.is_correct) }}
                    {{ form_label(form.is_correct, 'Mark as correct answer', {'label_attr': {'class': 'form-check-label'}}) }}
                </div>
                {% if form.is_correct.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.is_correct) }}</div>
                {% endif %}
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_answer_index') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check"></i> Create Answer
                </button>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
