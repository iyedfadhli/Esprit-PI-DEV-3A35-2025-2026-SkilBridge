{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Edit Course - {{ course.title }} - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <!-- Header -->
    <header class="admin-header">
        <h1><i class="fa-solid fa-pen"></i> Edit Course</h1>
    </header>

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_course_index') }}">Courses</a>
        <span>/</span>
        <a href="{{ path('admin_course_show', {'id': course.id}) }}">{{ course.title }}</a>
        <span>/</span>
        <span>Edit</span>
    </nav>

    <!-- Form Card -->
    <div class="card">
        <div class="card-header">
            <h2><i class="fa-solid fa-book"></i> Edit: {{ course.title }}</h2>
            <span class="badge badge-secondary">#{{ course.id }}</span>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'crud-form', 'novalidate': 'novalidate'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.title) }}
                    {% if form.title.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.title) }}
                        </div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.creator, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.creator) }}
                    {% if form.creator.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.creator) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description) }}
                {% if form.description.vars.errors|length > 0 %}
                    <div class="form-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        {{ form_errors(form.description) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.duration, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.duration) }}
                    {% if form.duration.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.duration) }}
                        </div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.validation_score, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.validation_score) }}
                    {% if form.validation_score.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.validation_score) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.content) }}
                    {% if form.content.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.content) }}
                        </div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.material, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.material) }}
                    {% if form.material.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            {{ form_errors(form.material) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.prerequisite_quiz, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.prerequisite_quiz) }}
                {% if form.prerequisite_quiz.vars.errors|length > 0 %}
                    <div class="form-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        {{ form_errors(form.prerequisite_quiz) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_course_index') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <a href="{{ path('admin_course_show', {'id': course.id}) }}" class="btn btn-outline">
                    <i class="fa-solid fa-eye"></i> View
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check"></i> Save Changes
                </button>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
