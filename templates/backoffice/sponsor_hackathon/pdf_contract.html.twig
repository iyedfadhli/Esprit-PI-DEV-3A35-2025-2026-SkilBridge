<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Sponsorship Contract</title>
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; color: #333; line-height: 1.6; }
        .header { text-align: center; margin-bottom: 50px; border-bottom: 2px solid #4a7fd7; padding-bottom: 20px; }
        .logo { max-width: 150px; margin-bottom: 10px; }
        .title { font-size: 24px; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; color: #2c3e50; }
        .content { margin-bottom: 40px; }
        .section { margin-bottom: 20px; }
        .section-title { font-size: 16px; font-weight: bold; color: #4a7fd7; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 10px; }
        .row { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .label { font-weight: bold; width: 150px; display: inline-block; }
        .value { color: #555; }
        .qr-section { text-align: center; margin: 40px 0; }
        .signatures { margin-top: 60px; width: 100%; }
        .signature-box { width: 45%; float: left; border: 1px dashed #ccc; height: 120px; margin-right: 5%; position: relative; }
        .signature-box:last-child { margin-right: 0; }
        .sign-label { position: absolute; bottom: 10px; left: 10px; font-size: 12px; color: #999; font-weight: bold; }
        .footer { text-align: center; font-size: 10px; color: #aaa; margin-top: 50px; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">Sponsorship Agreement</h1>
        <p>Ref: SP-{{ sponsor_hackathon.id }}-{{ "now"|date("Y") }}</p>
    </div>

    <div class="content">
        <div class="section">
            <div class="section-title">Parties Involved</div>
            <p><span class="label">Sponsor:</span> <span class="value">{{ sponsor_hackathon.sponsor.name }}</span></p>
            <p><span class="label">Hackathon:</span> <span class="value">{{ sponsor_hackathon.hackathon.title }}</span></p>
            <p><span class="label">Date:</span> <span class="value">{{ "now"|date("d F, Y") }}</span></p>
        </div>

        <div class="section">
            <div class="section-title">Contribution Details</div>
            <p><span class="label">Type:</span> <span class="value">{{ sponsor_hackathon.contributionType }}</span></p>
            <p><span class="label">Value:</span> <span class="value">{{ sponsor_hackathon.contributionValue|number_format(2) }} TND</span></p>
        </div>

        <div class="section">
            <div class="section-title">Terms & Conditions</div>
            <p>This agreement confirms the sponsorship commitment described above. The Sponsor agrees to provide the specified contribution, and the Hackathon organizers agree to provide the benefits associated with this sponsorship level.</p>
        </div>
    </div>


    <div class="signatures">
        <div class="signature-box">
            <span class="sign-label">Sponsor Signature</span>
        </div>
        <div class="signature-box" style="float: right;">
            <span class="sign-label">Organizer Signature</span>
        </div>
        <div style="clear: both;"></div>
    </div>

    <div class="footer">
        Generated by Skill Bridge Admin System on {{ "now"|date("Y-m-d H:i:s") }}
    </div>
</body>
</html>
