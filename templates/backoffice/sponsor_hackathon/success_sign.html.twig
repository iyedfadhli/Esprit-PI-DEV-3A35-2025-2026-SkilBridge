{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Payment successful – Sign contract{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .success-card { max-width: 560px; margin: 2rem auto; background: rgba(255,255,255,0.95); border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .success-badge { display: inline-flex; align-items: center; gap: 8px; color: #0d8050; font-weight: 600; margin-bottom: 1rem; }
    .success-badge i { font-size: 1.5rem; }
    .sign-modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9998; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .sign-modal { background: #fff; border-radius: 16px; padding: 2rem; max-width: 480px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
    .sign-modal h3 { margin: 0 0 1rem; font-size: 1.25rem; }
    .sign-canvas-wrap { border: 2px solid #ddd; border-radius: 8px; background: #fafafa; margin: 1rem 0; }
    #signCanvas { display: block; width: 100%; cursor: crosshair; border-radius: 6px; }
    .sign-actions { display: flex; gap: 10px; margin-top: 1rem; flex-wrap: wrap; }
    .sign-actions button { padding: 10px 20px; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; }
    .btn-clear { background: #f0f0f0; color: #333; }
    .btn-save { background: #4a7fd7; color: #fff; }
    .btn-download { background: #0d8050; color: #fff; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; border-radius: 8px; font-weight: 600; margin-top: 1rem; }
    .signed-done { color: #0d8050; font-weight: 600; margin-top: 1rem; }
</style>
{% endblock %}

{% block body %}
<div class="admin-header">
    <h1>Sponsorship payment successful</h1>
    <div class="admin-user">
        <a href="{{ path('app_back_sponsor_hackathon_index') }}" class="primary-btn" style="background: #6c757d;">
            <i class="fa fa-arrow-left"></i> Back to list
        </a>
    </div>
</div>

<div class="success-card">
    <div class="success-badge">
        <i class="fa-solid fa-circle-check"></i>
        Payment successful
    </div>
    <p><strong>{{ sponsor_hackathon.sponsor.name }}</strong> – {{ sponsor_hackathon.hackathon.title }} ({{ sponsor_hackathon.contributionType }}: {{ sponsor_hackathon.contributionValue|number_format(2) }} TND)</p>

    <p>Please sign the sponsorship contract below. When you sign and click "Save &amp; Download", you will get the signed contract as PDF (signature is not stored).</p>
    <button type="button" class="primary-btn" id="openSignModalBtn" style="margin-top: 1rem;">
        <i class="fa-solid fa-pen-fancy"></i> Sign &amp; download contract
    </button>
</div>

<div class="sign-modal-backdrop" id="signModal" style="display: none;">
    <div class="sign-modal">
        <h3>Sign the contract</h3>
        <p style="margin: 0 0 0.5rem; color: #666; font-size: 0.9rem;">Draw your signature in the box below.</p>
        <div class="sign-canvas-wrap">
            <canvas id="signCanvas" width="420" height="180"></canvas>
        </div>
        <div class="sign-actions">
            <button type="button" class="btn-clear" id="clearSignBtn">Clear</button>
            <button type="button" class="btn-save" id="saveSignBtn">Save &amp; Download PDF</button>
        </div>
        <p id="signError" style="color: #c00; font-size: 0.9rem; margin-top: 0.5rem; display: none;"></p>
    </div>
</div>

<script>
(function() {
    const modal = document.getElementById('signModal');
    const canvas = document.getElementById('signCanvas');
    const ctx = canvas.getContext('2d');
    const openBtn = document.getElementById('openSignModalBtn');
    const clearBtn = document.getElementById('clearSignBtn');
    const saveBtn = document.getElementById('saveSignBtn');
    const signError = document.getElementById('signError');
    const sponsorHackathonId = {{ sponsor_hackathon.id }};

    let drawing = false;
    let lastX = 0, lastY = 0;

    function initCanvas() {
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        ctx.fillStyle = '#fafafa';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
    initCanvas();

    canvas.addEventListener('mousedown', function(e) {
        drawing = true;
        const r = canvas.getBoundingClientRect();
        lastX = (e.clientX - r.left) * (canvas.width / r.width);
        lastY = (e.clientY - r.top) * (canvas.height / r.height);
    });
    canvas.addEventListener('mousemove', function(e) {
        if (!drawing) return;
        const r = canvas.getBoundingClientRect();
        const x = (e.clientX - r.left) * (canvas.width / r.width);
        const y = (e.clientY - r.top) * (canvas.height / r.height);
        ctx.beginPath();
        ctx.moveTo(lastX, lastY);
        ctx.lineTo(x, y);
        ctx.stroke();
        lastX = x;
        lastY = y;
    });
    canvas.addEventListener('mouseup', () => drawing = false);
    canvas.addEventListener('mouseleave', () => drawing = false);

    openBtn.addEventListener('click', function() {
        modal.style.display = 'flex';
        initCanvas();
        signError.style.display = 'none';
    });
    modal.addEventListener('click', function(e) {
        if (e.target === modal) modal.style.display = 'none';
    });
    clearBtn.addEventListener('click', initCanvas);

    saveBtn.addEventListener('click', function() {
        const dataUrl = canvas.toDataURL('image/png');
        const blank = document.createElement('canvas');
        blank.width = canvas.width;
        blank.height = canvas.height;
        const bctx = blank.getContext('2d');
        bctx.fillStyle = '#fafafa';
        bctx.fillRect(0, 0, blank.width, blank.height);
        if (dataUrl === blank.toDataURL('image/png')) {
            signError.textContent = 'Please draw your signature first.';
            signError.style.display = 'block';
            return;
        }
        signError.style.display = 'none';
        saveBtn.disabled = true;

        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '{{ path('app_back_sponsor_hackathon_pdf_signed', { id: sponsor_hackathon.id }) }}';
        form.target = '_blank';
        var sig = document.createElement('input');
        sig.type = 'hidden';
        sig.name = 'signature';
        sig.value = dataUrl;
        form.appendChild(sig);
        var tok = document.createElement('input');
        tok.type = 'hidden';
        tok.name = '_token';
        tok.value = '{{ csrf_token('pdf_signed' ~ sponsor_hackathon.id) }}';
        form.appendChild(tok);
        document.body.appendChild(form);
        form.submit();
        document.body.removeChild(form);
        modal.style.display = 'none';
        saveBtn.disabled = false;
    });
})();
</script>
{% endblock %}
