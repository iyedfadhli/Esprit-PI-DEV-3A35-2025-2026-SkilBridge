<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>{% block title %}Skill Bridge Back Office{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Stylesheets -->
    <link rel="stylesheet" href="{{ asset('assets/css/backoffice/dashboard/backoffice.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/backoffice/crud.css') }}">

    <link rel="shortcut icon" href="{{ asset('assets/images/frontoffice/logo.png') }}" type="image/x-icon">

    {% block stylesheets %}{% endblock %}
</head>

<body>

{% if user.getMainRoleLabel() == 'Admin'%}

<div class="admin-layout">

        <!-- Mobile Toggle -->
        <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open')">
            <i class="fa-solid fa-bars"></i>
        </button>

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="{{ asset('assets/images/frontoffice/logo.png') }}" alt="Skill Bridge Logo" class="sidebar-logo-img">
            </div>

            <nav class="sidebar-menu">
                <a class="active" href="{{ path('dashboard') }}"><i class="fa fa-dashboard"></i> Dashboard</a>
                <a href="{{ path('dashboard_user') }}"><i class="fa fa-user"></i> Users</a>
                <a href="{{ path('admin_course_index') }}"><i class="fa fa-book"></i> Courses</a>
                <a href="{{ path('admin_groups') }}"><i class="fa fa-users"></i> Groups</a>
                <a href="{{ path('admin_posts') }}"><i class="fa fa-file-text"></i> Posts</a>
                <a href="#"><i class="fa fa-trophy"></i> Challenges</a>
                <a href="#"><i class="fa fa-file-text"></i> CV & Internship</a>
                <a href="{{ path('app_back_hackathon_index') }}"><i class="fa fa-lightbulb-o"></i> Hackathon</a>
                <a href="{{path('home')}}"><i class="fa fa-home"></i> FrontOffice</a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="admin-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} fade-in">
                        {% if label == 'success' %}
                            <i class="fa-solid fa-circle-check"></i>
                        {% elseif label == 'danger' or label == 'error' %}
                            <i class="fa-solid fa-circle-exclamation"></i>
                        {% elseif label == 'warning' %}
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        {% else %}
                            <i class="fa-solid fa-circle-info"></i>
                        {% endif %}
                        <span>{{ message }}</span>
                    </div>
                {% endfor %}
            {% endfor %}
            
            {% block body %}{% endblock %}
        </main>

</div>

{% else %}
    <script>
        window.location.href = "{{ path('groups_index') }}";
    </script>
{% endif %}

{% block javascripts %}{% endblock %}

</body>
</html>
