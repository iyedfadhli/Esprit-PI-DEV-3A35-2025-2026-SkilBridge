{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Question #{{ question.id }} - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <header class="admin-header">
        <h1><i class="fa-solid fa-circle-question"></i> Question Details</h1>
        <div class="header-actions">
            <a href="{{ path('admin_answer_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Add Answer
            </a>
            <a href="{{ path('admin_question_edit', {'id': question.id}) }}" class="btn btn-warning">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form method="post" action="{{ path('admin_question_delete', {'id': question.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Delete</button>
            </form>
        </div>
    </header>

    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_question_index') }}">Questions</a>
        <span>/</span>
        <span>Question #{{ question.id }}</span>
    </nav>

    <div class="detail-grid">
        <div class="card">
            <div class="card-header">
                <h2><i class="fa-solid fa-info-circle"></i> Question Information</h2>
                <span class="badge badge-secondary">#{{ question.id }}</span>
            </div>
            <div class="card-body">
                <div class="detail-item">
                    <div class="detail-label">Content</div>
                    <div class="detail-value">{{ question.content }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Quiz</div>
                    <div class="detail-value">
                        <a href="{{ path('admin_quiz_show', {'id': question.quiz.id}) }}">
                            {{ question.quiz.title }} <i class="fa-solid fa-external-link"></i>
                        </a>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Course</div>
                    <div class="detail-value">
                        <a href="{{ path('admin_course_show', {'id': question.quiz.course.id}) }}">
                            {{ question.quiz.course.title }}
                        </a>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Type</div>
                    <div class="detail-value">
                        <span class="badge badge-{{ question.type == 'multiple_choice' ? 'primary' : (question.type == 'single_choice' ? 'success' : 'warning') }}">
                            {{ question.type|replace({'_': ' '})|title }}
                        </span>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Points</div>
                    <div class="detail-value">
                        <span class="badge badge-primary">{{ question.point }} pts</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2><i class="fa-solid fa-check-double"></i> Answers ({{ question.answers|length }})</h2>
                <a href="{{ path('admin_answer_new') }}" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body">
                {% if question.answers|length > 0 %}
                    {% for answer in question.answers %}
                    <div class="detail-item d-flex justify-between align-center">
                        <div class="d-flex align-center gap-2">
                            {% if answer.isCorrect %}
                                <span class="badge badge-success"><i class="fa-solid fa-check"></i> Correct</span>
                            {% else %}
                                <span class="badge badge-danger"><i class="fa-solid fa-xmark"></i> Wrong</span>
                            {% endif %}
                            <span>{{ answer.content }}</span>
                        </div>
                        <div class="action-buttons">
                            <a href="{{ path('admin_answer_edit', {'id': answer.id}) }}" class="btn btn-icon btn-sm btn-warning">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form method="post" action="{{ path('admin_answer_delete', {'id': answer.id}) }}" style="display: inline;" onsubmit="return confirm('Delete this answer?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ answer.id) }}">
                                <button type="submit" class="btn btn-icon btn-sm btn-danger">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">
                        <i class="fa-solid fa-check-double"></i>
                        <p>No answers yet</p>
                        <a href="{{ path('admin_answer_new') }}" class="btn btn-sm btn-primary">Add Answer</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('admin_question_index') }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Questions
        </a>
        <a href="{{ path('admin_quiz_show', {'id': question.quiz.id}) }}" class="btn btn-outline">
            <i class="fa-solid fa-clipboard-question"></i> View Quiz
        </a>
    </div>
</div>
{% endblock %}
