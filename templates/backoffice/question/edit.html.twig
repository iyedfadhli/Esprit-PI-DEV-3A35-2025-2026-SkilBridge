{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Edit Question - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <header class="admin-header">
        <h1><i class="fa-solid fa-pen"></i> Edit Question</h1>
    </header>

    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_question_index') }}">Questions</a>
        <span>/</span>
        <a href="{{ path('admin_question_show', {'id': question.id}) }}">Question #{{ question.id }}</a>
        <span>/</span>
        <span>Edit</span>
    </nav>

    <div class="card">
        <div class="card-header">
            <h2><i class="fa-solid fa-circle-question"></i> Edit Question</h2>
            <span class="badge badge-secondary">#{{ question.id }}</span>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'crud-form', 'novalidate': 'novalidate'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.quiz, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.quiz) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.type) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.content) }}
            </div>

            <div class="form-group">
                {{ form_label(form.point, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.point) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_question_index') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <a href="{{ path('admin_question_show', {'id': question.id}) }}" class="btn btn-outline">
                    <i class="fa-solid fa-eye"></i> View
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check"></i> Save Changes
                </button>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
