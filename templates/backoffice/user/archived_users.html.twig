{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Archived Users{% endblock %}

{% block body %}
<div style="padding:30px">

    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show mb-4 rounded-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h2 style="margin:0;"><i class="fa fa-archive" style="color:#f39c12;"></i> Archived Users</h2>

        <a href="{{ path('dashboard_user') }}"
           style="background:#5a7bd8; color:white; padding:10px 18px; border-radius:8px; text-decoration:none;">
            <i class="fa fa-arrow-left"></i> Back to Users
        </a>
    </div>

    <br>

    <table style="width:100%; border-collapse:collapse; background:#ffffff; border-radius:12px; overflow:hidden;">
        <thead>
            <tr style="background:#f39c12; color:white;">
                <th style="padding:14px; border:1px solid #e0e0e0;">ID</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Nom</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Prénom</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Email</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Type</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Date Inscrit</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Ban</th>
                <th style="padding:14px; border:1px solid #e0e0e0;">Restaurer</th>
            </tr>
        </thead>

        <tbody>
            {% for u in archivedUsers %}
                <tr>
                    <td style="padding:12px; border:1px solid #e0e0e0;">#{{ u.id }}</td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">{{ u.nom }}</td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">{{ u.prenom|default('—') }}</td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">{{ u.email }}</td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">
                        <span style="background:#45b36b; color:white; padding:6px 14px; border-radius:20px;">
                            {{ u.getMainRoleLabel() }}
                        </span>
                    </td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">
                        {{ u.dateInscrit ? u.dateInscrit|date('Y-m-d') : '—' }}
                    </td>
                    <td style="padding:12px; border:1px solid #e0e0e0;">
                        {% if u.ban %}
                            <span style="background:#e74c3c; color:white; padding:6px 14px; border-radius:20px;">BANNED</span>
                        {% else %}
                            <span style="background:#2ecc71; color:white; padding:6px 14px; border-radius:20px;">OK</span>
                        {% endif %}
                    </td>
                    <td style="padding:12px; border:1px solid #e0e0e0; text-align:center;">
                        <form method="post"
                              action="{{ path('admin_user_unarchive', {'id': u.id}) }}"
                              onsubmit="return confirm('Restaurer cet utilisateur ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('unarchive_user_' ~ u.id) }}">
                            <button type="submit"
                                    style="background:#10b981; color:white; border:none; padding:6px 14px; border-radius:8px; cursor:pointer; font-weight:600;"
                                    title="Restaurer cet utilisateur">
                                <i class="fa fa-undo"></i> Restaurer
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" style="padding:30px; text-align:center; color:#999;">
                        <i class="fa fa-archive" style="font-size:2em; margin-bottom:10px; display:block; color:#ddd;"></i>
                        Aucun utilisateur archivé
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
