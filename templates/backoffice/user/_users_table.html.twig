<table style="width:100%; border-collapse:collapse; background:#ffffff; border-radius:12px; overflow:hidden;">
    <thead>
        <tr style="background:#5a7bd8; color:white;">
            <th style="padding:14px; border:1px solid #e0e0e0;">ID</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Nom</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Prénom</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Date Naissance</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Email</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Ban</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Photo</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Mot de passe</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Date Inscrit</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Type</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Education</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Skills</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Experience</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Domaine</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Edit</th>
            <th style="padding:14px; border:1px solid #e0e0e0;">Archiver</th>
        </tr>
    </thead>

    <tbody>
        {% for u in users %}
            <tr>
                <!-- ID -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    #{{ u.id }}
                </td>

                <!-- Nom -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.nom }}
                </td>

                <!-- Prenom -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.prenom|default('—') }}
                </td>

                <!-- Date Naissance -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.dateNaissance ? u.dateNaissance|date('Y-m-d') : '—' }}
                </td>

                <!-- Email -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.email }}
                </td>

                <!-- Ban -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {% if u.ban %}
                        <span style="background:#e74c3c; color:white; padding:6px 14px; border-radius:20px;">
                            BANNED
                        </span>
                    {% else %}
                        <span style="background:#2ecc71; color:white; padding:6px 14px; border-radius:20px;">
                            OK
                        </span>
                    {% endif %}
                </td>

                <!-- Photo -->
                <td style="padding:12px; border:1px solid #e0e0e0; text-align:center;">
                    {% if u.photo %}
                        <img src="{{ asset(u.photo) }}"
                             alt="photo"
                             style="width:40px; height:40px; border-radius:50%; object-fit:cover;">
                    {% else %}
                        <span style="display:inline-block; width:40px; height:40px; border-radius:50%; background:#ddd;"></span>
                    {% endif %}
                </td>

                <!-- Password masked -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    ••••••••
                </td>

                <!-- ✅ Date Inscrit (CORRECT FIELD) -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.dateInscrit ? u.dateInscrit|date('Y-m-d') : '—' }}
                </td>

                <!-- Type -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    <span style="background:#45b36b; color:white; padding:6px 14px; border-radius:20px;">
                        {{ u.getMainRoleLabel() }}
                    </span>
                </td>

                <!-- Education -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.education|default('—') }}
                </td>

                <!-- Skills -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.skills|default('—') }}
                </td>

                <!-- Experience -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.experience|default('—') }}
                </td>

                <!-- Domaine -->
                <td style="padding:12px; border:1px solid #e0e0e0;">
                    {{ u.domaine|default('—') }}
                </td>

                <!-- Edit Button -->
                <td style="padding:12px; border:1px solid #e0e0e0; text-align:center;">
                    <a href="{{ path('admin_user_edit', {'id': u.id}) }}"
                       style="background:none; border:none; color:#3b82f6; cursor:pointer; text-decoration:none;">
                        <i class="fa fa-edit"></i>
                    </a>
                </td>

                <!-- Archive Button -->
                <td style="padding:12px; border:1px solid #e0e0e0; text-align:center;">
                    <form method="post"
                          action="{{ path('admin_user_archive', {'id': u.id}) }}"
                          onsubmit="return confirm('Êtes-vous sûr de vouloir archiver cet utilisateur ?');">

                        <input type="hidden"
                               name="_token"
                               value="{{ csrf_token('archive_user_' ~ u.id) }}">

                        <button type="submit"
                                style="background:none; border:none; color:#f39c12; cursor:pointer;"
                                title="Archiver cet utilisateur">
                            <i class="fa fa-archive"></i>
                        </button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="16" style="padding:20px; text-align:center;">
                    No users found
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>