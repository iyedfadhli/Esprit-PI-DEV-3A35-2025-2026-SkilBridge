{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}
<div style="padding:30px">

    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h2 style="margin:0;">Users Management</h2>

        <div style="display:flex; gap:10px;">
            <a href="{{ path('admin_users_export_pdf') }}"
               style="background:#10b981; color:white; padding:10px 18px; border-radius:8px; text-decoration:none;">
                <i class="fa fa-file-pdf"></i> Export PDF
            </a>

            <a href="{{ path('admin_user_new') }}"
               style="background:#5a7bd8; color:white; padding:10px 18px; border-radius:8px; text-decoration:none;">
                <i class="fa fa-plus"></i> Add User
            </a>
        </div>
    </div>

    <br>

    <div style="margin-bottom: 20px;">
        <input type="text" id="userSearch" placeholder="Search users by name, email..." 
               style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 8px;">
    </div>

    <div id="usersTable">
        {% include 'backoffice/user/_users_table.html.twig' %}
    </div>

    <script>
        document.getElementById('userSearch').addEventListener('keyup', function() {
            let query = this.value;
            fetch("{{ path('dashboard_user') }}?search=" + query, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('usersTable').innerHTML = html;
            });
        });
    </script>

</div>
{% endblock %}
