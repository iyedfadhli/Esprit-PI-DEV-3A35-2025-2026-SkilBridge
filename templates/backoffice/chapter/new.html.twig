{% extends 'backoffice/base_back.html.twig' %}

{% block title %}New Chapter - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <!-- Header -->
    <header class="admin-header">
        <h1><i class="fa-solid fa-plus"></i> Create New Chapter</h1>
    </header>

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_chapter_index') }}">Chapters</a>
        <span>/</span>
        <span>New</span>
    </nav>

    <!-- Form Card -->
    <div class="card">
        <div class="card-header">
            <h2><i class="fa-solid fa-bookmark"></i> Chapter Information</h2>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'crud-form', 'novalidate': 'novalidate'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.title) }}
                    {% if form.title.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.title) }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.course, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.course) }}
                    {% if form.course.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.course) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.chapter_order, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.chapter_order) }}
                    {% if form.chapter_order.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.chapter_order) }}</div>
                    {% endif %}
                    <div class="form-hint">Position in the course (1, 2, 3...)</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.status, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.status) }}
                    {% if form.status.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.status) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.min_score, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.min_score) }}
                    {% if form.min_score.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.min_score) }}</div>
                    {% endif %}
                    <div class="form-hint">Minimum score to pass the chapter quiz</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.content) }}
                    {% if form.content.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.content) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_chapter_index') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check"></i> Create Chapter
                </button>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
