{% extends 'backoffice/base_back.html.twig' %}

{% block title %}Chapters - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <!-- Header -->
    <header class="admin-header">
        <h1><i class="fa-solid fa-bookmark"></i> Chapters Management</h1>
        <div class="header-actions">
            <a href="{{ path('admin_chapter_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Add New Chapter
            </a>
        </div>
    </header>

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <span>Chapters</span>
    </nav>

    <!-- Quick Nav Tabs -->
    <div class="nav-tabs">
        <a href="{{ path('admin_course_index') }}">Courses</a>
        <a href="{{ path('admin_chapter_index') }}" class="active">Chapters</a>
        <a href="{{ path('admin_quiz_index') }}">Quizzes</a>
        <a href="{{ path('admin_question_index') }}">Questions</a>
        <a href="{{ path('admin_answer_index') }}">Answers</a>
    </div>

    <!-- Section Title with Count -->
    <div class="section-title">
        <h2>All Chapters</h2>
        <span class="count">{{ total }}</span>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <form class="search-box" method="get">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" value="{{ search }}" placeholder="Search chapters...">
        </form>
    </div>

    <!-- Data Card -->
    <div class="card">
        {% if chapters|length > 0 %}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Order</th>
                        <th>Chapter</th>
                        <th>Course</th>
                        <th>Status</th>
                        <th>Min Score</th>
                        <th>Quiz</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chapter in chapters %}
                    <tr>
                        <td><span class="badge badge-secondary">#{{ chapter.id }}</span></td>
                        <td><span class="badge badge-primary">{{ chapter.chapterOrder }}</span></td>
                        <td>
                            <div class="cell-title">{{ chapter.title }}</div>
                        </td>
                        <td>
                            <a href="{{ path('admin_course_show', {'id': chapter.course.id}) }}">
                                {{ chapter.course.title }}
                            </a>
                        </td>
                        <td>
                            <span class="badge badge-{{ chapter.status == 'published' ? 'success' : (chapter.status == 'draft' ? 'warning' : 'secondary') }}">
                                {{ chapter.status }}
                            </span>
                        </td>
                        <td><span class="badge badge-success">{{ chapter.minScore }}%</span></td>
                        <td>
                            {% if chapter.quiz %}
                                <a href="{{ path('admin_quiz_show', {'id': chapter.quiz.id}) }}" class="badge badge-primary">
                                    <i class="fa-solid fa-clipboard-question"></i> {{ chapter.quiz.title }}
                                </a>
                            {% else %}
                                <span class="badge badge-secondary">No quiz</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('admin_chapter_show', {'id': chapter.id}) }}" class="btn btn-icon btn-sm btn-secondary" data-tooltip="View">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_chapter_edit', {'id': chapter.id}) }}" class="btn btn-icon btn-sm btn-warning" data-tooltip="Edit">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form method="post" action="{{ path('admin_chapter_delete', {'id': chapter.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this chapter?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapter.id) }}">
                                    <button type="submit" class="btn btn-icon btn-sm btn-danger" data-tooltip="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if totalPages > 1 %}
        <div class="card-footer">
            <div class="pagination">
                <span class="pagination-info">Showing page {{ currentPage }} of {{ totalPages }}</span>
                
                {% if currentPage > 1 %}
                    <a href="{{ path('admin_chapter_index', {'page': 1, 'search': search}) }}"><i class="fa-solid fa-angles-left"></i></a>
                    <a href="{{ path('admin_chapter_index', {'page': currentPage - 1, 'search': search}) }}"><i class="fa-solid fa-angle-left"></i></a>
                {% endif %}
                
                {% for p in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                    <a href="{{ path('admin_chapter_index', {'page': p, 'search': search}) }}" class="{{ p == currentPage ? 'active' : '' }}">{{ p }}</a>
                {% endfor %}
                
                {% if currentPage < totalPages %}
                    <a href="{{ path('admin_chapter_index', {'page': currentPage + 1, 'search': search}) }}"><i class="fa-solid fa-angle-right"></i></a>
                    <a href="{{ path('admin_chapter_index', {'page': totalPages, 'search': search}) }}"><i class="fa-solid fa-angles-right"></i></a>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {% else %}
        <div class="empty-state">
            <i class="fa-solid fa-bookmark"></i>
            <h3>No chapters found</h3>
            <p>Get started by creating your first chapter</p>
            <a href="{{ path('admin_chapter_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Create Chapter
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
