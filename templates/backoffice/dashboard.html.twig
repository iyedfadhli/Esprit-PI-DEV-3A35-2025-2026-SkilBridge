				<i class="fa fa-user-circle"></i>
				<span>Admin</span>
			</div>
		</header>

		<section class="stats-grid">
			<div class="stat-card">
				<h3>users</h3>
				<p class="stat-number">{{ totalUsers }}</p>
			</div>

			{# Les autres cards restent comme elles sont pour le moment #}
