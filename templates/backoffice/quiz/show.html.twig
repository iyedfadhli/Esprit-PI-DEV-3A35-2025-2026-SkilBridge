{% extends 'backoffice/base_back.html.twig' %}

{% block title %}{{ quiz.title }} - Skill Bridge{% endblock %}

{% block body %}
<div class="slide-up">
    <!-- Header -->
    <header class="admin-header">
        <h1><i class="fa-solid fa-clipboard-question"></i> {{ quiz.title }}</h1>
        <div class="header-actions">
            <button id="btn-translate" class="btn btn-info" onclick="translateQuiz()" style="background:#3b82f6;color:#fff;border:none;cursor:pointer;">
                <i class="fa-solid fa-language"></i> Translate to English
            </button>
            <a href="{{ path('admin_question_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Add Question
            </a>
            <a href="{{ path('admin_quiz_edit', {'id': quiz.id}) }}" class="btn btn-warning">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form method="post" action="{{ path('admin_quiz_delete', {'id': quiz.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </header>

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
        <a href="{{ path('dashboard') }}">Dashboard</a>
        <span>/</span>
        <a href="{{ path('admin_quiz_index') }}">Quizzes</a>
        <span>/</span>
        <span>{{ quiz.title }}</span>
    </nav>

    <!-- Stats Overview -->
    <div class="stats-grid">
        <div class="stat-card">
            <h3>Passing Score</h3>
            <p class="stat-number">{{ quiz.passingScore }}%</p>
        </div>
        <div class="stat-card">
            <h3>Max Attempts</h3>
            <p class="stat-number">{{ quiz.maxAttempts }}</p>
        </div>
        <div class="stat-card">
            <h3>Questions/Attempt</h3>
            <p class="stat-number">{{ quiz.questionsPerAttempt ?: 'All' }}</p>
        </div>
    </div>

    <div class="detail-grid">
        <!-- Quiz Information Card -->
        <div class="card">
            <div class="card-header">
                <h2><i class="fa-solid fa-info-circle"></i> Quiz Information</h2>
                <span class="badge badge-secondary">#{{ quiz.id }}</span>
            </div>
            <div class="card-body">
                <div class="detail-item">
                    <div class="detail-label">Title</div>
                    <div class="detail-value">{{ quiz.title }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Course</div>
                    <div class="detail-value">
                        <a href="{{ path('admin_course_show', {'id': quiz.course.id}) }}">
                            {{ quiz.course.title }} <i class="fa-solid fa-external-link"></i>
                        </a>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Chapter</div>
                    <div class="detail-value">
                        {% if quiz.chapter %}
                            <a href="{{ path('admin_chapter_show', {'id': quiz.chapter.id}) }}">
                                {{ quiz.chapter.title }} <i class="fa-solid fa-external-link"></i>
                            </a>
                        {% else %}
                            <span class="badge badge-secondary">Course-level quiz</span>
                        {% endif %}
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Supervisor</div>
                    <div class="detail-value">{{ quiz.supervisor ? quiz.supervisor.email : 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Passing Score</div>
                    <div class="detail-value">
                        <span class="badge badge-success">{{ quiz.passingScore }}%</span>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Maximum Attempts</div>
                    <div class="detail-value">{{ quiz.maxAttempts }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Questions per Attempt</div>
                    <div class="detail-value">{{ quiz.questionsPerAttempt ?: 'All questions' }}</div>
                </div>
            </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="card">
            <div class="card-header">
                <h2><i class="fa-solid fa-bolt"></i> Quick Actions</h2>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-2">
                    <a href="{{ path('admin_question_new') }}" class="btn btn-primary">
                        <i class="fa-solid fa-plus"></i> Add New Question
                    </a>
                    <a href="{{ path('admin_question_index', {'quiz': quiz.id}) }}" class="btn btn-outline">
                        <i class="fa-solid fa-list"></i> View All Questions
                    </a>
                    <a href="{{ path('admin_course_show', {'id': quiz.course.id}) }}" class="btn btn-secondary">
                        <i class="fa-solid fa-book"></i> Back to Course
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Translation Result Section (hidden by default) -->
    <div id="translation-section" style="display:none;" class="mt-3">
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                <h2><i class="fa-solid fa-language"></i> English Translation</h2>
                <button class="btn btn-sm btn-secondary" onclick="closeTranslation()" style="cursor:pointer;">
                    <i class="fa-solid fa-xmark"></i> Close
                </button>
            </div>
            <div class="card-body">
                <!-- Translated Title -->
                <div class="detail-item" style="margin-bottom:1rem;">
                    <div class="detail-label" style="font-weight:700;">Title (EN)</div>
                    <div class="detail-value" id="translated-title" style="font-size:1.15rem;"></div>
                </div>

                <!-- Translated Questions -->
                <div id="translated-questions"></div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-3">
        <a href="{{ path('admin_quiz_index') }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Quizzes
        </a>
    </div>
</div>

<script>
const QUIZ_ID = {{ quiz.id }};

async function translateQuiz() {
    const btn = document.getElementById('btn-translate');
    const section = document.getElementById('translation-section');

    // Show loading state
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Translating…';

    try {
        const resp = await fetch(`/api/quizzes/${QUIZ_ID}/translate?target_lang=en&source_lang=fr`);
        if (!resp.ok) throw new Error('Translation API error: ' + resp.status);
        const data = await resp.json();

        // Populate title
        document.getElementById('translated-title').textContent = data.translated.title;

        // Populate questions
        const container = document.getElementById('translated-questions');
        container.innerHTML = '';

        if (data.translated.questions.length === 0) {
            container.innerHTML = '<p style="color:#6b7280;">No questions found for this quiz.</p>';
        } else {
            data.translated.questions.forEach((q, idx) => {
                const qDiv = document.createElement('div');
                qDiv.style.cssText = 'border:1px solid #e5e7eb;border-radius:10px;padding:1rem;margin-bottom:1rem;background:#f9fafb;';

                let answersHtml = '';
                q.answers.forEach(a => {
                    const icon = a.is_correct
                        ? '<i class="fa-solid fa-circle-check" style="color:#16a34a;"></i>'
                        : '<i class="fa-regular fa-circle" style="color:#9ca3af;"></i>';
                    answersHtml += `<li style="padding:4px 0;">${icon} ${escapeHtml(a.content)}</li>`;
                });

                qDiv.innerHTML = `
                    <h4 style="margin:0 0 .5rem;"><span class="badge badge-secondary">#${q.id}</span> Question ${idx + 1}</h4>
                    <p style="font-size:1.05rem;margin:0 0 .5rem;">${escapeHtml(q.content)}</p>
                    <ul style="list-style:none;padding:0;margin:0;">${answersHtml}</ul>
                `;
                container.appendChild(qDiv);
            });
        }

        section.style.display = 'block';
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Update button to allow re-translate
        btn.innerHTML = '<i class="fa-solid fa-language"></i> Refresh Translation';
    } catch (err) {
        alert('Translation failed: ' + err.message);
        btn.innerHTML = '<i class="fa-solid fa-language"></i> Translate to English';
    } finally {
        btn.disabled = false;
    }
}

function closeTranslation() {
    document.getElementById('translation-section').style.display = 'none';
    const btn = document.getElementById('btn-translate');
    btn.innerHTML = '<i class="fa-solid fa-language"></i> Translate to English';
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>
{% endblock %}
