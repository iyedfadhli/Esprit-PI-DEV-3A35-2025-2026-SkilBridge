{% extends 'backoffice/base_back.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/backoffice/challenge/challenge.css') }}">
	<style>
		.table-controls {
			margin-bottom: 15px;
			display: flex;
			gap: 10px;
			align-items: center;
		}

		.table-controls input[type="text"] {
			padding: 5px 10px;
			border: 1px solid #ccc;
			border-radius: 4px;
			width: 200px;
		}

		.table-controls select {
			padding: 5px 10px;
			border: 1px solid #ccc;
			border-radius: 4px;
		}

		.table-controls button {
			padding: 5px 15px;
			background-color: #4f46e5;
			color: white;
			border: none;
			border-radius: 4px;
			cursor: pointer;
		}

		.table-controls button:hover {
			background-color: #4338ca;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="admin-wrapper">

		<h2 class="page-title">Challenge & Activity & Evaluations</h2>

		<div class="tabs">
			<button class="tab active" data-target="challenge-wrapper">Challenge</button>
			<button class="tab" data-target="activity-wrapper">Activity</button>
			<button class="tab" data-target="evaluation-wrapper">Evaluation</button>
		</div>

		<div
			class="table-container">

			<div id="challenge-wrapper" class="table-wrapper">
				<form method="get" action="{{ path('challengeback') }}">
					<input type="hidden" name="tab" value="challenge-wrapper">

					<div class="table-controls">
						<input type="text" name="challenge_search" placeholder="Search Challenge..." value="{{ challengeSearch|default('') }}">

						<select name="challenge_sort">
							<option value="">Sort by</option>
							<option value="ID" {% if challengeSort|default('') == 'ID' %} selected {% endif %}>ID</option>
							<option value="Title" {% if challengeSort|default('') == 'Title' %} selected {% endif %}>Title</option>
							<option value="Difficulty" {% if challengeSort|default('') == 'Difficulty' %} selected {% endif %}>Difficulty</option>
						</select>

						<button type="submit">Go</button>
					</div>
				</form>

				<table class="evaluation-table">
					<thead>
						<tr>
							<th>ID</th>
							<th>Title</th>
							<th>Description</th>
							<th>Target Skill</th>
							<th>Difficulty</th>
							<th>Min Group</th>
							<th>Max Group</th>
							<th>Deadline</th>
							<th>Created At</th>
							<th>Creator ID</th>
							<th>Course ID</th>
							<th>Content</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for challenge in challenges %}
							<tr>
								<td>#{{ challenge.id }}</td>
								<td>{{ challenge.title }}</td>
								<td>{{ challenge.description }}</td>
								<td>{{ challenge.targetSkill }}</td>
								<td>{{ challenge.difficulty }}</td>
								<td>{{ challenge.minGroupNbr }}</td>
								<td>{{ challenge.maxGroupNbr }}</td>
								<td>{{ challenge.deadLine|date('Y-m-d') }}</td>
								<td>{{ challenge.createdAt|date('Y-m-d') }}</td>
								<td>{{ challenge.getCreator.id }}</td>
								<td>{{ challenge.getCourse.id }}</td>
								<td>
									<a href="{{ asset('' ~ challenge.content) }}" target="_blank">
										View Challenge content
									</a>
								</td>
								<td>
									<form action="{{ path('backoffice_challenge_delete', {id: challenge.id}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this challenge?');">
										<button class="btn edit-btn" type="submit">Delete</button>
									</form>
								</td>

							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

			<div id="activity-wrapper" class="table-wrapper">
				<form method="get" action="{{ path('challengeback') }}">
					<input type="hidden" name="tab" value="activity-wrapper">

					<div class="table-controls">
						<input type="text" name="activity_search" placeholder="Search Activity..." value="{{ activitySearch|default('') }}">

						<select name="activity_sort">
							<option value="">Sort by</option>
							<option value="ID" {% if activitySort|default('') == 'ID' %} selected {% endif %}>ID</option>
							
						</select>

						<button type="submit">Go</button>
					</div>
				</form>

				<table class="evaluation-table">
					<thead>
						<tr>
							<th>ID</th>
							<th>Submission file</th>
							<th>Submission date</th>
							<th>Status</th>
							<th>groupID</th>
							<th>challengeID</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for activity in activities %}
							<tr>
								<td>#{{ activity.id }}</td>
								<td>
									{% if activity.submissionFile %}
										<a href="{{ asset('assets/challenge/pdf/' ~ activity.submissionFile) }}" target="_blank">
											View File
										</a>
									{% else %}
										No file
									{% endif %}
								</td>
								<td>
                                    {{ activity.submissionDate ? activity.submissionDate|date('Y-m-d H:i') : '—' }}</td>
								<td>
									{{activity.status}}</td>
								<td>
									{{activity.getGroupId.id}}</td>
								<td>
									{{activity.getIdChallenge.id}}</td>


								<td>
									<form action="{{ path('backoffice_activity_delete', {id: activity.id}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this activity?');">
										<button class="btn edit-btn" type="submit">Delete</button>
									</form>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

			<div id="evaluation-wrapper" class="table-wrapper">
				<form method="get" action="{{ path('challengeback') }}">
					<input type="hidden" name="tab" value="evaluation-wrapper">

					<div class="table-controls">
						<input type="text" name="evaluation_search" placeholder="Search Evaluation..." value="{{ evaluation_search|default('') }}">

						<select name="evaluation_sort">
							<option value="">Sort by</option>
							<option value="ID" {% if sortBy|default('') == 'ID' %} selected {% endif %}>
								ID
							</option>
							<option value="Group Score" {% if sortBy|default('') == 'Group Score' %} selected {% endif %}>
								Group Score
							</option>
						</select>

						<button type="submit">Go</button>
					</div>
				</form>

				<table class="evaluation-table">
					<thead>
						<tr>
							<th>ID</th>
							<th>Group Score</th>
							<th>Feedback</th>
							<th>Pre-feedback</th>
							<th>Activity ID</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for eval in evaluations %}
							<tr>
								<td>#{{ eval.id }}</td>
								<td>{{ eval.groupScore }}</td>
								<td>
									<a href="{{ asset('' ~ eval.feedback) }}" target="_blank">
										View Feedback
									</a>
								</td>
								<td>{{ eval.preFeedback }}</td>
								<td>{{ eval.getActivityId.id }}</td>
								<td>
									<form action="{{ path('backoffice_evaluation_delete', {id: eval.id}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this activity?');">
										<button class="btn edit-btn" type="submit">Delete</button>
									</form>
								</td>
							</tr>
						{% endfor %}
					</tbody>

				</table>
			</div>

		</div>

	</div>
{% endblock %}

{% block javascripts %}
	 <script>
		const tabs = document.querySelectorAll('.tab');
		const wrappers = document.querySelectorAll('.table-wrapper');
		
		function activateTab(targetId) {
		    tabs.forEach(t => t.classList.remove('active'));
		    wrappers.forEach(w => w.style.display = 'none');
		
		    const activeButton = document.querySelector(`[data-target="${targetId}"]`);
		    if (activeButton) {
		        activeButton.classList.add('active');
		    }
		
		    const activeWrapper = document.getElementById(targetId);
		    if (activeWrapper) {
		        activeWrapper.style.display = 'block';
		    }
		}
		
		tabs.forEach(tab => {
		    tab.addEventListener('click', () => {
		        activateTab(tab.getAttribute('data-target'));
		    });
		});
		
		activateTab("{{ activeTab|default('challenge-wrapper') }}");
		</script>

{% endblock %}
