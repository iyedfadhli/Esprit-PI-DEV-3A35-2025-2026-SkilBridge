<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ course.title }} - Skill Bridge</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 11pt;
            line-height: 1.6;
            color: #1f2937;
            background: #fff;
        }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 30px;
            margin-bottom: 30px;
        }
        
        .header-content {
            max-width: 100%;
        }
        
        .logo {
            font-size: 24pt;
            font-weight: bold;
            margin-bottom: 20px;
            letter-spacing: -1px;
        }
        
        .logo span {
            color: #c7d2fe;
        }
        
        .course-title {
            font-size: 22pt;
            font-weight: bold;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        
        .course-meta {
            font-size: 10pt;
            opacity: 0.9;
        }
        
        .course-meta span {
            margin-right: 20px;
        }
        
        /* Content Area */
        .content {
            padding: 0 30px 30px;
        }
        
        /* Info Box */
        .info-box {
            background: #f8fafc;
            border-left: 4px solid #667eea;
            padding: 20px;
            margin-bottom: 30px;
        }
        
        .info-box h3 {
            color: #667eea;
            font-size: 12pt;
            margin-bottom: 10px;
        }
        
        .info-grid {
            display: table;
            width: 100%;
        }
        
        .info-item {
            display: table-cell;
            width: 33%;
            padding: 10px 0;
        }
        
        .info-label {
            font-size: 9pt;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .info-value {
            font-size: 14pt;
            font-weight: bold;
            color: #1f2937;
        }
        
        /* Section */
        .section {
            margin-bottom: 30px;
        }
        
        .section-title {
            font-size: 14pt;
            font-weight: bold;
            color: #1f2937;
            border-bottom: 2px solid #667eea;
            padding-bottom: 8px;
            margin-bottom: 15px;
        }
        
        .section-content {
            text-align: justify;
        }
        
        /* Chapter Card */
        .chapter {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            page-break-inside: avoid;
        }
        
        .chapter-header {
            margin-bottom: 15px;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 10px;
        }
        
        .chapter-number {
            display: inline-block;
            background: #667eea;
            color: white;
            width: 28px;
            height: 28px;
            line-height: 28px;
            text-align: center;
            border-radius: 50%;
            font-size: 10pt;
            font-weight: bold;
            margin-right: 10px;
        }
        
        .chapter-title {
            font-size: 13pt;
            font-weight: bold;
            color: #1f2937;
        }
        
        .chapter-content {
            color: #374151;
            text-align: justify;
        }
        
        /* Table of Contents */
        .toc {
            margin-bottom: 30px;
        }
        
        .toc-title {
            font-size: 14pt;
            font-weight: bold;
            color: #1f2937;
            border-bottom: 2px solid #667eea;
            padding-bottom: 8px;
            margin-bottom: 15px;
        }
        
        .toc-item {
            padding: 8px 0;
            border-bottom: 1px dotted #d1d5db;
        }
        
        .toc-number {
            display: inline-block;
            width: 25px;
            color: #667eea;
            font-weight: bold;
        }
        
        /* Footer */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #f8fafc;
            border-top: 1px solid #e5e7eb;
            padding: 15px 30px;
            font-size: 9pt;
            color: #6b7280;
        }
        
        .footer-content {
            display: table;
            width: 100%;
        }
        
        .footer-left {
            display: table-cell;
            text-align: left;
        }
        
        .footer-right {
            display: table-cell;
            text-align: right;
        }
        
        /* Page Break */
        .page-break {
            page-break-after: always;
        }
        
        /* Utilities */
        .text-muted {
            color: #6b7280;
        }
        
        .text-primary {
            color: #667eea;
        }
        
        .mt-20 {
            margin-top: 20px;
        }
        
        .mb-20 {
            margin-bottom: 20px;
        }
        
        /* Badge */
        .badge {
            display: inline-block;
            background: #dbeafe;
            color: #1d4ed8;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 9pt;
            font-weight: 600;
        }
        
        .badge-success {
            background: #d1fae5;
            color: #059669;
        }
        
        /* Watermark */
        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 100pt;
            color: rgba(102, 126, 234, 0.03);
            font-weight: bold;
            z-index: -1;
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="watermark">Skill Bridge</div>
    
    <!-- Header -->
    <div class="header">
        <div class="header-content">
            <div class="logo">Skill<span>Bridge</span></div>
            <div class="course-title">{{ course.title }}</div>
            <div class="course-meta">
                <span>📚 {{ chapters|length }} Chapitre{% if chapters|length > 1 %}s{% endif %}</span>
                <span>⏱️ {{ course.duration }} minutes</span>
                {% if course.creator %}
                    <span>👤 {{ course.creator.prenom|default('') }} {{ course.creator.nom|default('Formateur') }}</span>
                {% endif %}
            </div>
        </div>
    </div>
    
    <div class="content">
        <!-- Course Info -->
        <div class="info-box">
            <h3>📋 Informations du cours</h3>
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Durée estimée</div>
                    <div class="info-value">{{ course.duration }} min</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Score requis</div>
                    <div class="info-value">{{ course.validationScore|default(70) }}%</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Exporté le</div>
                    <div class="info-value">{{ exportDate|date('d/m/Y') }}</div>
                </div>
            </div>
        </div>
        
        <!-- Description -->
        <div class="section">
            <div class="section-title">📝 Description</div>
            <div class="section-content">
                {{ course.description|raw }}
            </div>
        </div>
        
        <!-- Table of Contents -->
        {% if chapters|length > 0 %}
            <div class="toc">
                <div class="toc-title">📑 Table des matières</div>
                {% for item in chapters %}
                    <div class="toc-item">
                        <span class="toc-number">{{ loop.index }}.</span>
                        {{ item.chapter.title }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        
        <!-- Content Summary -->
        {% if course.content %}
            <div class="section">
                <div class="section-title">📖 Contenu du cours</div>
                <div class="section-content">
                    {{ course.content|raw }}
                </div>
            </div>
        {% endif %}
        
        <!-- Chapters -->
        {% if chapters|length > 0 %}
            <div class="page-break"></div>
            
            <div class="section">
                <div class="section-title">📚 Chapitres du cours</div>
                
                {% for item in chapters %}
                    <div class="chapter">
                        <div class="chapter-header">
                            <span class="chapter-number">{{ loop.index }}</span>
                            <span class="chapter-title">{{ item.chapter.title }}</span>
                            {% if item.quiz %}
                                <span class="badge" style="float: right;">Quiz disponible</span>
                            {% endif %}
                        </div>
                        <div class="chapter-content">
                            {{ item.chapter.content|raw }}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        
        <!-- Notes Section -->
        <div class="section mt-20">
            <div class="section-title">✏️ Notes personnelles</div>
            <div style="border: 1px dashed #d1d5db; border-radius: 8px; padding: 30px; min-height: 150px; background: #fafafa;">
                <p class="text-muted" style="font-style: italic; font-size: 10pt;">
                    Utilisez cet espace pour prendre des notes pendant votre apprentissage...
                </p>
            </div>
        </div>
    </div>
    
    <!-- Footer -->
    <div class="footer">
        <div class="footer-content">
            <div class="footer-left">
                <strong>Skill Bridge</strong> - Plateforme d'apprentissage en ligne
            </div>
            <div class="footer-right">
                Document généré le {{ exportDate|date('d/m/Y à H:i') }}
            </div>
        </div>
    </div>
</body>
</html>
